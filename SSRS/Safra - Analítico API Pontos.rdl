    <DataSource Name="Staging">
      <ConnectionProperties>
        <DataProvider>SQL</DataProvider>
        <ConnectString>Data Source=10.10.20.103</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:SecurityType>Integrated</rd:SecurityType>
      <rd:DataSourceID>97d904ff-13a0-42f1-8bc5-d70fe9ab0cc4</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DS_DADOS">
      <Query>
        <DataSourceName>Staging</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DAT_INI">
            <Value>=Parameters!DAT_INI.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@DAT_FIM">
            <Value>=Parameters!DAT_FIM.Value</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
          <QueryParameter Name="@STATUS">
            <Value>=JOIN(Parameters!STATUS.Value, ",")</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
	CPF
	,VOP
	,PONTOS
	,STATUS
	,TIPO
	,NUMERO_NOTA
	,ERROR
	,DATA_CRIACAO
FROM
	DB_SAFRA_API.dbo.TB_RETORNO_PONTOS_REP (NOLOCK)
WHERE
	CAST(DATA_CRIACAO AS DATE) BETWEEN @DAT_INI AND @DAT_FIM
	and STATUS IN (SELECT Des_Filtro FROM DB_VENDAVALL4.dbo.fn_segmenta_filtro(CONVERT(VARCHAR(MAX), @STATUS)))</CommandText>
      </Query>
      <Fields>
        <Field Name="VOP">
          <DataField>VOP</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="CPF">
          <DataField>CPF</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TIPO">
          <DataField>TIPO</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PONTOS">
          <DataField>PONTOS</DataField>
          <rd:TypeName>System.Double</rd:TypeName>
        </Field>
        <Field Name="NUMERO_NOTA">
          <DataField>NUMERO_NOTA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ERROR">
          <DataField>ERROR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DATA_CRIACAO">
          <DataField>DATA_CRIACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_STATUS">
      <Query>
        <DataSourceName>Staging</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@DAT_INI">
            <Value>=Parameters!DAT_INI.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@DAT_FIM">
            <Value>=Parameters!DAT_FIM.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
	DISTINCT STATUS
FROM
	DB_SAFRA_API.dbo.TB_RETORNO_PONTOS_REP (NOLOCK)
WHERE
	CAST(DATA_CRIACAO AS DATE) BETWEEN @DAT_INI AND @DAT_FIM</CommandText>
      </Query>
      <Fields>
        <Field Name="STATUS">
          <DataField>STATUS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
