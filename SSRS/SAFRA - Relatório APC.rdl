  <Code>Public Function MascararCPF(cpf As String) As String
    If cpf.Length = 11 Then
        Return cpf.Substring(0, 3) &amp; "******" &amp; cpf.Substring(9, 2)
    Else
        Return cpf
    End If
End Function

Public Function MascararNumero(numero As String) As String
    If numero.Length = 11 Then
        ' Máscara para números com 11 dígitos (exemplo: 123******45)
        Return numero.Substring(0, 3) &amp; "******" &amp; numero.Substring(9, 2)
    ElseIf numero.Length = 14 Then
        ' Máscara para números com 14 dígitos (exemplo: 12******000156)
        Return numero.Substring(0, 2) &amp; "******" &amp; numero.Substring(8, 6)
    Else
        ' Se não tiver 11 ou 14 dígitos, retorna o número original
        Return numero
    End If
End Function

Public Function FormatarDataParaBrasileiro(data As String) As String
    If IsDate(data) Then
        ' Converte a string para data e formata no padrão dd/MM/yyyy
        Return Format(CDate(data), "dd/MM/yyyy")
    Else
        ' Se o valor não for uma data válida, retorna o valor original
        Return data
    End If
End Function</Code>
