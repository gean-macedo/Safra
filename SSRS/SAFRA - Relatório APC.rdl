  <DataSets>
    <DataSet Name="DS_QUALITATIVA">
      <Query>
        <DataSourceName>Staging</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ANO">
            <Value>=JOIN(Parameters!ANO.Value,",")</Value>
            <rd:UserDefined>true</rd:UserDefined>
          </QueryParameter>
        </QueryParameters>
        <CommandText>--BASE QUALITATIVA
 -----TESTE-----
 --DECLARE @ANO INT = 2026;

WITH Calendario AS (
    SELECT 
		DISTINCT 
		D.NUM_ANO AS ANO_REF, 
		D.NUM_MES AS MES_REF, 
		D.DESC_MES, 
		D.PERIODO
	FROM DB_MARKUP.MKP.D_DATAS D
	WHERE NUM_ANO in (SELECT Des_Filtro FROM DB_VENDAVALL4.dbo.fn_segmenta_filtro(CONVERT(VARCHAR, @ANO)))
),
Participantes AS (
    SELECT 
        P.ID_PARTICIPANTE,
		P.ID,
        P.CPF,
        P.NOME,
        P.ID_USUARIO,
        P.DATA_ACEITE_REGULAMENTO,
        P.STATUS
    FROM DB_SAFRA.dbo.TB_PARTICIPANTES P WITH (NOLOCK)
),
EstabUnico AS (
    SELECT 
        EP.ID_PARTICIPANTE,
        EP.ID_ESTABELECIMENTO,
        ROW_NUMBER() OVER (
            PARTITION BY EP.ID_PARTICIPANTE 
            ORDER BY EP.created_at DESC
        ) AS RN
    FROM DB_SAFRA.dbo.TB_ESTABELECIMENTOS_PARTICIPANTES EP WITH (NOLOCK)
),
Pontos AS (
    SELECT 
        PO.ID_PARTICIPANTE,
		SUM(PO.REAIS_CREDITADOS) AS VALOR_CREDITADO,
        SUM(CASE WHEN FLAG_EXPIRADO = 0 THEN PO.SALDO_REAIS ELSE 0 END) AS VALOR_SALDO,
        YEAR(PO.DATA_CREDITO) AS ANO_REF,
        MONTH(PO.DATA_CREDITO) AS MES_REF
    FROM DB_PREMIOIDEAL.dbo.TB_PONTOS PO WITH (NOLOCK)
	JOIN Calendario C 
		ON YEAR(PO.DATA_CREDITO) = C.ANO_REF
		AND  MONTH(PO.DATA_CREDITO) = C.MES_REF
    WHERE PO.ID_CAMPANHA = 375
    GROUP BY PO.ID_PARTICIPANTE, YEAR(PO.DATA_CREDITO), MONTH(PO.DATA_CREDITO)
),
Expirados AS (
    SELECT 
        PO.ID_PARTICIPANTE,
        SUM(CASE WHEN FLAG_EXPIRADO = 1 THEN PO.SALDO_REAIS ELSE 0 END) AS VALOR_EXPIRADO,
        YEAR(PO.DATA_EXPIRACAO) AS ANO_REF,
        MONTH(PO.DATA_EXPIRACAO) AS MES_REF
    FROM DB_PREMIOIDEAL.dbo.TB_PONTOS PO WITH (NOLOCK)
	JOIN Calendario C 
		ON YEAR(PO.DATA_EXPIRACAO) = C.ANO_REF
		AND MONTH(PO.DATA_EXPIRACAO) = C.MES_REF
    WHERE PO.ID_CAMPANHA = 375
    GROUP BY PO.ID_PARTICIPANTE, YEAR(PO.DATA_EXPIRACAO), MONTH(PO.DATA_EXPIRACAO)
),
AExpirar AS (
    SELECT 
        PO.ID_PARTICIPANTE,
        SUM(PO.SALDO_REAIS) AS VALOR_A_EXPIRAR,
        YEAR(PO.DATA_EXPIRACAO) AS ANO_REF,
        MONTH(PO.DATA_EXPIRACAO) AS MES_REF
    FROM DB_PREMIOIDEAL.dbo.TB_PONTOS PO WITH (NOLOCK)
	JOIN Calendario C 
		ON YEAR(PO.DATA_EXPIRACAO) = C.ANO_REF
		AND MONTH(PO.DATA_EXPIRACAO) = C.MES_REF
    WHERE PO.ID_CAMPANHA = 375
      AND PO.FLAG_EXPIRADO = 0            
      AND PO.DATA_EXPIRACAO &gt; GETDATE()
    GROUP BY PO.ID_PARTICIPANTE, YEAR(PO.DATA_EXPIRACAO), MONTH(PO.DATA_EXPIRACAO)
),
Resgates AS (
    SELECT 
        PR.CPF_PARTICIPANTE,
        SUM(PR.VALOR_RESGASTADO) AS VALOR_RESGATADO,
        YEAR(PR.DATA_RESGATE) AS ANO_REF,
        MONTH(PR.DATA_RESGATE) AS MES_REF
    FROM DB_PREMIOIDEAL.dbo.TB_PONTOS_RESGATADOS PR WITH (NOLOCK)
	JOIN Calendario C 
		ON YEAR(PR.DATA_RESGATE) = C.ANO_REF
		AND MONTH(PR.DATA_RESGATE) = C.MES_REF
    WHERE PR.ID_CAMPANHA = 375
    GROUP BY PR.CPF_PARTICIPANTE, YEAR(PR.DATA_RESGATE), MONTH(PR.DATA_RESGATE)
),
Acessos AS (
    SELECT 
        AV.USER_ID,
        COUNT(DISTINCT AV.DATE_TIME) AS QTD_ACESSOS,
        YEAR(AV.DATE_TIME) AS ANO_REF,
        MONTH(AV.DATE_TIME) AS MES_REF
    FROM DB_VENDAVALL4.dbo.TB_ACESSOS_VENDAVALL AV WITH (NOLOCK)
	JOIN Calendario C 
		ON YEAR(AV.DATE_TIME) = C.ANO_REF
		AND MONTH(AV.DATE_TIME) = C.MES_REF
    WHERE AV.CLIENTE = 'SAFRA'
      AND AV.VISITED_PAGE = 'Página de login'
    GROUP BY AV.USER_ID, YEAR(AV.DATE_TIME), MONTH(AV.DATE_TIME)
),
Chamados AS (
    SELECT 
        OC.CNPJ_CPF,
        COUNT(DISTINCT OC.ID_OCORRENCIA) AS QTD_CHAMADOS,
        YEAR(OC.DATA_ABERTURA) AS ANO_REF,
        MONTH(OC.DATA_ABERTURA) AS MES_REF
    FROM DB_DIALLINK.dbo.TB_OCORRENCIAS OC WITH (NOLOCK)
	JOIN Calendario C 
		ON YEAR(OC.DATA_ABERTURA) = C.ANO_REF
		AND MONTH(OC.DATA_ABERTURA) = C.MES_REF
    WHERE OC.ID_CAMPANHA = 375
    GROUP BY OC.CNPJ_CPF, YEAR(OC.DATA_ABERTURA), MONTH(OC.DATA_ABERTURA)
),
Contratos AS(
SELECT
	CPF
	,CAST(REPLACE(LEFT(DATA_VENDA,7),'-','') AS INT)						AS PERIODO
	,SUM(QUANTIDADE)						AS CONTRATOS
FROM
	DB_SAFRA.DBO.TB_VENDAS					A (NOLOCK)
GROUP BY
	CPF
	,CAST(REPLACE(LEFT(DATA_VENDA,7),'-','') AS INT)
)

SELECT 
    E.CNPJ,
    E.ID_REVENDA										AS CD_REVENDA,
    LEFT(P.CPF, 6)										AS CD_VENDEDOR,
	P.ID AS ID_PARTICIPANTE,
    P.NOME												AS NM_VENDEDOR,
    P.DATA_ACEITE_REGULAMENTO							AS DT_ATIVACAO,
    P.STATUS											AS STATUS_ATUAL,
	ISNULL(CO.CONTRATOS,0)								AS CONTRATOS,
	CAST(ISNULL(Po.VALOR_CREDITADO,0) AS DECIMAL(18,2)) AS VALOR_CREDITADO,
    CAST(ISNULL(Po.VALOR_SALDO,0) AS DECIMAL(18,2))     AS VALOR_DISPONIVEL,
    CAST(ISNULL(Ex.VALOR_EXPIRADO,0) AS DECIMAL(18,2))  AS VALOR_EXPIRADO,
    CAST(ISNULL(Ax.VALOR_A_EXPIRAR,0) AS DECIMAL(18,2)) AS VALOR_A_EXPIRAR,
    CAST(ISNULL(Pr.VALOR_RESGATADO,0) AS DECIMAL(18,2)) AS VALOR_RESGATADO,
    ISNULL(Av.QTD_ACESSOS,0)							AS QTD_ACESSOS,
    ISNULL(Ch.QTD_CHAMADOS,0)							AS QTD_CHAMADOS,
    C.ANO_REF,
    C.MES_REF
FROM Calendario C
CROSS JOIN Participantes P
LEFT JOIN EstabUnico EU 
    ON EU.ID_PARTICIPANTE = P.ID_PARTICIPANTE
   AND EU.RN = 1
LEFT JOIN DB_SAFRA.dbo.TB_ESTABELECIMENTOS E WITH (NOLOCK)
    ON E.ID_ESTABELECIMENTO = EU.ID_ESTABELECIMENTO
LEFT JOIN DB_PREMIOIDEAL.dbo.TB_PARTICIPANTES PA WITH (NOLOCK)
    ON PA.CPF = P.CPF
LEFT JOIN Pontos Po 
    ON Po.ID_PARTICIPANTE = PA.ID_PARTICIPANTE
   AND Po.ANO_REF = C.ANO_REF
   AND Po.MES_REF = C.MES_REF
LEFT JOIN Expirados Ex
    ON Ex.ID_PARTICIPANTE = PA.ID_PARTICIPANTE
   AND Ex.ANO_REF = C.ANO_REF
   AND Ex.MES_REF = C.MES_REF
LEFT JOIN AExpirar Ax
    ON Ax.ID_PARTICIPANTE = PA.ID_PARTICIPANTE
   AND Ax.ANO_REF = C.ANO_REF
   AND Ax.MES_REF = C.MES_REF
LEFT JOIN Resgates Pr 
    ON Pr.CPF_PARTICIPANTE = P.CPF COLLATE SQL_Latin1_General_CP1_CI_AS
   AND Pr.ANO_REF = C.ANO_REF
   AND Pr.MES_REF = C.MES_REF
LEFT JOIN Acessos Av 
    ON Av.USER_ID = P.ID_USUARIO
   AND Av.ANO_REF = C.ANO_REF
   AND Av.MES_REF = C.MES_REF
LEFT JOIN Chamados Ch 
    ON Ch.CNPJ_CPF = P.CPF
   AND Ch.ANO_REF = C.ANO_REF
   AND Ch.MES_REF = C.MES_REF
LEFT JOIN Contratos	Co
	ON P.CPF = CO.CPF
	AND C.PERIODO = CO.PERIODO
WHERE 
    ISNULL(Po.VALOR_SALDO,0)
  + ISNULL(Ex.VALOR_EXPIRADO,0)
  + ISNULL(Ax.VALOR_A_EXPIRAR,0)
  + ISNULL(Pr.VALOR_RESGATADO,0)
  + ISNULL(Av.QTD_ACESSOS,0)
  + ISNULL(Ch.QTD_CHAMADOS,0)
  + ISNULL(CO.CONTRATOS,0) &gt; 0</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CNPJ">
          <DataField>CNPJ</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CD_REVENDA">
          <DataField>CD_REVENDA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CD_VENDEDOR">
          <DataField>CD_VENDEDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ID_PARTICIPANTE">
          <DataField>ID_PARTICIPANTE</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="NM_VENDEDOR">
          <DataField>NM_VENDEDOR</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_ATIVACAO">
          <DataField>DT_ATIVACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="STATUS_ATUAL">
          <DataField>STATUS_ATUAL</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VALOR_CREDITADO">
          <DataField>VALOR_CREDITADO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_DISPONIVEL">
          <DataField>VALOR_DISPONIVEL</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CONTRATOS">
          <DataField>CONTRATOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="VALOR_EXPIRADO">
          <DataField>VALOR_EXPIRADO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_A_EXPIRAR">
          <DataField>VALOR_A_EXPIRAR</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VALOR_RESGATADO">
          <DataField>VALOR_RESGATADO</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="QTD_ACESSOS">
          <DataField>QTD_ACESSOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_CHAMADOS">
          <DataField>QTD_CHAMADOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ANO_REF">
          <DataField>ANO_REF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="MES_REF">
          <DataField>MES_REF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_QUANTITATIVA">
      <Query>
        <DataSourceName>Staging</DataSourceName>
        <CommandText>--BASE QUANTITATIVA
 
WITH RULE_TERM AS (
	SELECT
		PARTICIPANT_ID,
		RULE_AND_TERM_ID,
		CREATED_AT
	FROM DB_SAFRA.DBO.TB_ACEITE_TERMOS_REGULAMENTOS WITH (NOLOCK)
)
SELECT
	ES.CNPJ,
	ES.ID_REVENDA																						AS CD_REVENDA,
	CAST(ES.CREATED_AT AS DATE)																			AS DT_CADASTRO,
	CASE 
		WHEN COUNT(DISTINCT CASE WHEN PA.STATUS = 'ATIVO' AND PH.NOME = 'MASTER' THEN PA.ID END) &gt; 0 
		THEN CAST(MIN(RL2.CREATED_AT) AS DATE) 
		ELSE NULL 
		END																								AS DT_ATIVACAO,
	CASE 
		WHEN ES.STATUS = 0 
		THEN CAST(ES.UPDATED_AT AS DATE) 
		END																								AS DT_INATIVACAO,
	COUNT(DISTINCT CASE WHEN PH.NOME = 'VENDEDOR' THEN PA.ID END)										AS QTD_VENDEDORES,
	COUNT(DISTINCT CASE WHEN PA.STATUS = 'ATIVO' AND PH.NOME = 'VENDEDOR' THEN PA.ID END)				AS QTD_VENDEDORES_ATIVOS,
	CASE 
		WHEN COUNT(DISTINCT CASE WHEN PA.STATUS = 'ATIVO' AND PH.NOME = 'VENDEDOR' THEN PA.ID END) &gt; 0 
		THEN CAST(MIN(RL.CREATED_AT) AS DATE) 
		ELSE NULL 
		END																								AS DT_ATIVACAO_VENDEDOR
FROM DB_SAFRA.DBO.TB_ESTABELECIMENTOS AS ES WITH (NOLOCK)
LEFT JOIN DB_SAFRA.DBO.TB_ESTABELECIMENTOS_PARTICIPANTES AS EP WITH (NOLOCK)
	ON ES.ID_ESTABELECIMENTO = EP.ID_ESTABELECIMENTO
LEFT JOIN DB_SAFRA.DBO.TB_PARTICIPANTES AS PA WITH (NOLOCK)
	ON EP.ID_PARTICIPANTE = PA.ID_PARTICIPANTE
LEFT JOIN DB_SAFRA.DBO.TB_PARTICIPANTE_PROGRAMA AS PP WITH (NOLOCK)
	ON PA.ID_PARTICIPANTE = PP.PARTICIPANT_ID
JOIN DB_SAFRA.DBO.TB_PROGRAMA_HIERARQUIA AS PH WITH (NOLOCK)
	ON PP.COMPANY_POSITION_ID = PH.ID_HIERARQUIA
LEFT JOIN RULE_TERM AS RL WITH (NOLOCK)
	ON RL.PARTICIPANT_ID = PA.ID_PARTICIPANTE
	AND PH.NOME = 'VENDEDOR'
LEFT JOIN RULE_TERM AS RL2 WITH (NOLOCK)
	ON RL2.PARTICIPANT_ID = PA.ID_PARTICIPANTE
	AND PH.NOME = 'MASTER'
GROUP BY
	ES.CNPJ,
	ES.CREATED_AT,
	ES.ID_REVENDA,
	ES.STATUS,
	ES.UPDATED_AT</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="CNPJ">
          <DataField>CNPJ</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CD_REVENDA">
          <DataField>CD_REVENDA</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DT_CADASTRO">
          <DataField>DT_CADASTRO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_ATIVACAO">
          <DataField>DT_ATIVACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="DT_INATIVACAO">
          <DataField>DT_INATIVACAO</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="QTD_VENDEDORES">
          <DataField>QTD_VENDEDORES</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="QTD_VENDEDORES_ATIVOS">
          <DataField>QTD_VENDEDORES_ATIVOS</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="DT_ATIVACAO_VENDEDOR">
          <DataField>DT_ATIVACAO_VENDEDOR</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="DS_CALENDARIO">
      <Query>
        <DataSourceName>Staging</DataSourceName>
        <CommandText>SELECT DISTINCT ANO AS ANO_REF
FROM (
    SELECT YEAR(DATA_CREDITO)     AS ANO FROM DB_PREMIOIDEAL.dbo.TB_PONTOS WHERE ID_CAMPANHA = 375
    UNION ALL
    SELECT YEAR(DATA_EXPIRACAO)   AS ANO FROM DB_PREMIOIDEAL.dbo.TB_PONTOS WHERE ID_CAMPANHA = 375
    UNION ALL
    SELECT YEAR(DATA_EXPIRACAO)   AS ANO FROM DB_PREMIOIDEAL.dbo.TB_PONTOS WHERE ID_CAMPANHA = 375 AND FLAG_EXPIRADO = 0 AND DATA_EXPIRACAO &gt; GETDATE()
    UNION ALL
    SELECT YEAR(DATA_RESGATE)     AS ANO FROM DB_PREMIOIDEAL.dbo.TB_PONTOS_RESGATADOS WHERE ID_CAMPANHA = 375
    UNION ALL
    SELECT YEAR(DATE_TIME)        AS ANO FROM DB_VENDAVALL4.dbo.TB_ACESSOS_VENDAVALL WHERE CLIENTE = 'SAFRA' AND VISITED_PAGE = 'Página de login'
    UNION ALL
    SELECT YEAR(DATA_ABERTURA)    AS ANO FROM DB_DIALLINK.dbo.TB_OCORRENCIAS WHERE ID_CAMPANHA = 375
) AS Anos
WHERE ANO IS NOT NULL
ORDER BY ANO;</CommandText>
        <rd:UseGenericDesigner>true</rd:UseGenericDesigner>
      </Query>
      <Fields>
        <Field Name="ANO_REF">
          <DataField>ANO_REF</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
