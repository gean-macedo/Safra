          <components>
            <component
              refId="Package\Carrega TB_VENDAS_TEMP\ADO NET Source"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;4"
              description="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server."
              name="ADO NET Source"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement used by the component to extract data."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select p.cpf
	,e.cnpj 
	,sale_date
	,nf_number
	,qnty
	,item_value_total 
	,case 
		when s.cfop = '0' then 'Manual'
		else s.cfop end as tipo
	,s.additional_infos -&gt;&gt; 'data_referencia' as data_referencia
	,s.additional_infos -&gt;&gt; 'validade' as validade
	,s.additional_infos -&gt;&gt; 'placa_veiculo' as placa_veiculo
	,s.additional_infos -&gt;&gt; 'marca' as marca
	,s.additional_infos -&gt;&gt; 'modelo' as modelo
	,s.additional_infos -&gt;&gt; 'codigo_operador' as codigo_operador
	,s.additional_infos -&gt;&gt; 'codigo_safra_revenda' as codigo_safra_revenda
	,s.additional_infos -&gt;&gt; 'vop' as vop
,s.created_at::date as data_criacao
from safra_api_vendavall_20240828225002.sales s 
left join safra_api_vendavall_20240828225002.participants p
on s.saler_id = p.id
left join safra_api_vendavall_20240828225002.establishments e 
on s.establishment_id = e.id</property>
                <property
