        <SQLTask:SqlTaskData
          SQLTask:Connection="{0CD4C6B3-0338-4191-8BDB-28A96C9E270C}"
          SQLTask:SqlStatementSource="EXEC DB_MARKUP. [MKP].[SP_REGISTRA_LOG_ITEM] ?" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ParameterBinding
