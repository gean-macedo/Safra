    <DTS:Executable
      DTS:refId="Package\Correção datas Pre cadastro"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{CD6756B8-F8BD-42D9-8A1D-17DE0E99FD7F}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Correção datas Pre cadastro"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{0CD4C6B3-0338-4191-8BDB-28A96C9E270C}"
          SQLTask:SqlStatementSource="WITH TEMP AS (&#xA;SELECT&#xA;&#x9;*&#xA;FROM&#xA;&#x9;(&#xA;SELECT&#xA;&#x9;ID_PARTICIPANTE&#xA;&#x9;,ROW_NUMBER() OVER(PARTITION BY ID_PARTICIPANTE, ID_CARGO, DAT_INI_VIGENCIA, ID_PROGRAMA ORDER BY DATA_CRIACAO_PARTICIPANTE) AS VLD&#xA;FROM&#xA;&#x9;DB_TCLSEMP.DBO.D_PARTICIPANTES&#x9;(NOLOCK)&#xA;) A&#xA;WHERE&#xA;&#x9;VLD &gt; 1&#xA;)&#xA;&#xA;--SELECT *&#xA;&#x9;UPDATE A SET DAT_INI_VIGENCIA = NULL, DAT_FIM_VIGENCIA = NULL&#xA;FROM&#xA;&#x9;DB_TCLSEMP.DBO.D_PARTICIPANTES&#x9;A&#xA;&#x9;INNER JOIN TEMP B&#xA;&#x9;&#x9;ON A.ID_PARTICIPANTE = B.ID_PARTICIPANTE&#xA;WHERE&#xA;&#x9;status = 'Pre-cadastro'" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Registra item"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{E688EFB4-985D-4409-8F52-3388699F49B8}"
