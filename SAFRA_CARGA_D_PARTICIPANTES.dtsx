    <DTS:Executable
      DTS:refId="Package\Update DAT_FIM Pre Cadastro"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{0E044159-1642-4AF3-9424-2A92B513B2A2}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update DAT_FIM Pre Cadastro"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{0CD4C6B3-0338-4191-8BDB-28A96C9E270C}"
          SQLTask:SqlStatementSource="WITH DADOS_UPDATE AS(&#xA;SELECT&#xA;&#x9;PA.ID_PARTICIPANTE&#xA;&#x9;,MIN(DAT_INI_VIGENCIA)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DATA_FIM&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES&#x9;&#x9;&#x9;AS PA (NOLOCK)&#xA;WHERE&#xA;&#x9;STATUS = 'Ativo'&#xA;GROUP BY&#xA;&#x9;PA.ID_PARTICIPANTE&#xA;)&#xA;&#xA;&#xA;&#x9;UPDATE P SET DAT_FIM_VIGENCIA = DATEADD(DAY,-1,DATA_FIM)&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;P&#xA;&#x9;INNER JOIN DADOS_UPDATE&#x9;&#x9;&#x9;&#x9;&#x9;DP&#xA;&#x9;&#x9;ON P.ID_PARTICIPANTE = DP.ID_PARTICIPANTE&#xA;WHERE&#xA;&#x9;P.DAT_FIM_VIGENCIA IS NULL&#xA;&#x9;AND STATUS = 'Pre-Cadastro'" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Update DAT_FIM_VIGENCIA"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{3154EE4F-384B-4EE0-83C1-864F300E2270}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update DAT_FIM_VIGENCIA"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{0CD4C6B3-0338-4191-8BDB-28A96C9E270C}"
          SQLTask:SqlStatementSource="WITH VLD_UNICO AS(&#xA;SELECT&#xA;&#x9;ID&#xA;&#x9;,ID_PARTICIPANTE&#xA;FROM&#xA;&#x9;(&#xA;SELECT&#xA;&#x9;A.*&#xA;&#x9;,ROW_NUMBER() OVER(PARTITION BY ID_PARTICIPANTE, ID_PROGRAMA ORDER BY ID DESC) AS VLD&#xA;FROM&#xA;&#x9;dbo.D_PARTICIPANTES A (NOLOCK)&#xA;WHERE&#xA;&#x9;DATA_ACEITE_REGULAMENTO IS NOT NULL&#xA;) B&#xA;WHERE&#xA;&#x9;DAT_FIM_VIGENCIA IS NULL&#xA;&#x9;AND VLD &gt; 1&#xA;),&#xA;&#xA;DADOS_UPDATE AS(&#xA;SELECT&#xA;&#x9;PA.ID_PARTICIPANTE&#xA;&#x9;,MIN(PA.ID)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ID&#xA;&#x9;,MAX(DAT_INI_VIGENCIA)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DATA_FIM&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES&#x9;&#x9;&#x9;AS PA (NOLOCK)&#xA;&#x9;INNER JOIN VLD_UNICO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS VU &#xA;&#x9;&#x9;ON PA.ID_PARTICIPANTE = VU.ID_PARTICIPANTE&#xA;WHERE&#xA;&#x9;DAT_FIM_VIGENCIA IS NULL&#xA;GROUP BY&#xA;&#x9;PA.ID_PARTICIPANTE&#xA;)&#xA;&#xA;--SELECT *&#xA;&#x9;UPDATE P SET DAT_FIM_VIGENCIA = DATEADD(DAY,-1,DATA_FIM)&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;P&#xA;&#x9;INNER JOIN DADOS_UPDATE&#x9;&#x9;&#x9;&#x9;&#x9;DP&#xA;&#x9;&#x9;ON P.ID = DP.ID&#xA;WHERE&#xA;&#x9;P.DAT_FIM_VIGENCIA IS NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Update DAT_INI registro unico"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{6CF7ED7B-AE1B-4B86-B4FA-7F85FD3B5DE1}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update DAT_INI registro unico"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{0CD4C6B3-0338-4191-8BDB-28A96C9E270C}"
          SQLTask:SqlStatementSource="WITH VLD_UNICO AS(&#xA;SELECT&#xA;&#x9;*&#xA;FROM&#xA;&#x9;(&#xA;SELECT&#xA;&#x9;ID_PARTICIPANTE&#xA;&#x9;,ID_CARGO&#xA;&#x9;,DAT_INI_VIGENCIA&#xA;&#x9;,ROW_NUMBER() OVER(PARTITION BY ID_PARTICIPANTE, ID_PROGRAMA ORDER BY DATA_ATUALIZACAO_PARTICIPANTE) AS VLD&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES A (NOLOCK)&#xA;) A&#xA;WHERE&#xA;&#x9;VLD = 1&#xA;&#x9;AND DAT_INI_VIGENCIA IS NULL&#xA;)&#xA;&#xA;--SELECT *&#xA;&#x9;UPDATE A SET DAT_INI_VIGENCIA = IIF(STATUS = 'Pre-cadastro', DATEADD(DAY,1,EOMONTH(DATA_CRIACAO_PARTICIPANTE,-1)),DATEADD(DAY,1,EOMONTH(DATA_ACEITE_REGULAMENTO,-1)))&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS A (NOLOCK)&#xA;&#x9;INNER JOIN VLD_UNICO&#x9;&#x9;&#x9;&#x9;&#x9;AS V&#xA;&#x9;&#x9;ON A.ID_PARTICIPANTE = V.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND V.VLD = 1&#xA;WHERE&#xA;&#x9;A.DAT_INI_VIGENCIA IS NULL&#xA;&#x9;AND STATUS &lt;&gt; 'Inativo'" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Update DAT_INI_VIGENCIA novo cargo"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{CC194684-5D86-42EA-9880-2C1B9EE18C3C}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update DAT_INI_VIGENCIA novo cargo"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{0CD4C6B3-0338-4191-8BDB-28A96C9E270C}"
          SQLTask:SqlStatementSource="&#xA;WITH VLD_UNICO AS(&#xA;SELECT&#xA;&#x9;ID_PARTICIPANTE&#xA;&#x9;,ROW_NUMBER() OVER(PARTITION BY ID_PARTICIPANTE, ID_PROGRAMA ORDER BY DATA_ATUALIZACAO_PARTICIPANTE) AS VLD&#xA;FROM&#xA;&#x9;dbo.D_PARTICIPANTES A (NOLOCK)&#xA;)&#xA;&#xA;--SELECT *&#xA;UPDATE A SET DAT_INI_VIGENCIA = DATEADD(DAY,1,EOMONTH(DATA_ATUALIZACAO_PARTICIPANTE,-1))&#xA;FROM&#xA;&#x9;DBO.D_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS A&#xA;&#x9;INNER JOIN VLD_UNICO&#x9;&#x9;&#x9;&#x9;&#x9;AS VU&#xA;&#x9;&#x9;ON A.ID_PARTICIPANTE = VU.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND VU.VLD &gt; 1&#xA;WHERE&#xA;&#x9;A.DAT_INI_VIGENCIA IS NULL&#xA;&#x9;AND DATA_ACEITE_REGULAMENTO IS NOT NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
