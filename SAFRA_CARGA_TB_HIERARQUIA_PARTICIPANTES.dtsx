                  dataType="System.String"
                  description="Specifies the SQL statement used by the component to extract data."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select
	participant_id::text
	,rule_and_term_id::text
	,campaign_id::text
	,rt.program_id::text
	,rt.title
	,rt.description
	,prt.created_at
from
	safra_api_vendavall_20240828225002.participant_rule_and_term prt
join safra_api_vendavall_20240828225002.rule_and_terms rt
	on rt.id = prt.rule_and_term_id
	
	union
	
	select
	participant_id::text
	,rule_and_term_id::text
	,campaign_id::text
	,rt.program_id::text
	,rt.title
	,rt.description
	,prt.created_at
from
	safra_api_vendavall_20240828225002.participant_rule_and_term_history prt
join safra_api_vendavall_20240828225002.rule_and_terms rt
	on rt.id = prt.rule_and_term_id</property>
