    <DTS:Executable
      DTS:refId="Package\UPDATE DATA_FIM"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{7C869193-43C9-4592-B95C-7BB3F3268D7D}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="UPDATE DATA_FIM"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AB9690D2-407C-4CF7-A1F5-9D2443F0BF5A}"
          SQLTask:SqlStatementSource="WITH NOVOS_REGISTROS AS (&#xA;SELECT&#xA;&#x9;ID&#xA;&#x9;,ID_PARTICIPANTE&#xA;&#x9;,ID_PROGRAMA&#xA;&#x9;,DATA_INICIO&#xA;FROM&#xA;&#x9;(&#xA;SELECT&#xA;&#x9;*&#xA;&#x9;,ROW_NUMBER() OVER(PARTITION BY ID_PARTICIPANTE,ID_PROGRAMA ORDER BY DATA_INICIO) AS VLD&#xA;FROM&#xA;&#x9;DBO.TB_HIERARQUIA_PARTICIPANTES&#xA;) A&#xA;WHERE&#xA;&#x9;VLD &gt; 1&#xA;)&#xA;&#xA;&#xA;&#x9;UPDATE A SET DATA_FIM = DATEADD(DAY,-1,B.DATA_INICIO)&#xA;FROM&#xA;&#x9;DBO.TB_HIERARQUIA_PARTICIPANTES A&#xA;&#x9;INNER JOIN NOVOS_REGISTROS&#x9;B&#xA;&#x9;&#x9;ON A.ID_PARTICIPANTE = B.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND A.ID_PROGRAMA = B.ID_PROGRAMA&#xA;WHERE&#xA;&#x9;A.DATA_INICIO &lt; B.DATA_INICIO&#xA;&#x9;AND A.DATA_FIM IS NULL" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\UPDATE ID_VERSAO"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{ED6DF98F-00E7-4405-9012-C41F0B6E066F}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="UPDATE ID_VERSAO"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AB9690D2-407C-4CF7-A1F5-9D2443F0BF5A}"
          SQLTask:SqlStatementSource="-- INSERE UMA NOVA VERSÃO CASO TENHA UM NOVO CARGO&#xA;INSERT INTO DBO.TB_HIERARQUIA_PARTICIPANTES &#xA;    (ID_PARTICIPANTE, CPF, ID_HIERARQUIA, ID_PROGRAMA, DATA_INICIO, ID_VERSAO)&#xA;SELECT &#xA;    HPT.ID_PARTICIPANTE,&#xA;    HPT.CPF,&#xA;    HPT.ID_HIERARQUIA,&#xA;    HPT.ID_PROGRAMA,&#xA;    GETDATE() AS DATA_INICIO,&#xA;    ISNULL((&#xA;        SELECT MAX(HP2.ID_VERSAO)&#xA;        FROM DBO.TB_HIERARQUIA_PARTICIPANTES HP2&#xA;        WHERE HP2.ID_PARTICIPANTE = HPT.ID_PARTICIPANTE&#xA;    ), 0) + 1 AS ID_VERSAO&#xA;FROM &#xA;    DBO.TB_HIERARQUIA_PARTICIPANTES_TEMP AS HPT (NOLOCK)&#xA;WHERE &#xA;    NOT EXISTS (&#xA;        SELECT 1&#xA;        FROM DBO.TB_HIERARQUIA_PARTICIPANTES AS HP (NOLOCK)&#xA;        WHERE &#xA;            HP.ID_PARTICIPANTE = HPT.ID_PARTICIPANTE&#xA;            AND HP.ID_HIERARQUIA = HPT.ID_HIERARQUIA&#xA;            AND HP.ID_PROGRAMA = HPT.ID_PROGRAMA&#xA;    )&#xA;&#xA;--INSERE A VERSÃO 1 PARA OS NOVOS PARTICIPANTES&#xA;UPDATE HP&#xA;SET HP.ID_VERSAO = 1  &#xA;FROM DBO.TB_HIERARQUIA_PARTICIPANTES AS HP&#xA;INNER JOIN DBO.TB_HIERARQUIA_PARTICIPANTES_TEMP AS HPT (NOLOCK)&#xA;    ON HPT.id_participante = HP.ID_PARTICIPANTE&#xA;WHERE HP.ID_VERSAO IS NULL;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\UPDATE TB_PARTICIPANTES"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
