      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{AB9690D2-407C-4CF7-A1F5-9D2443F0BF5A}"
          SQLTask:SqlStatementSource="UPDATE A SET &#xA; NOME&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= UPPER(B.NOME)&#xA; ,RG&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= IIF(B.RG = 'null', NULL, B.RG)&#xA; ,CPF&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.CPF&#xA; ,DATA_NASCIMENTO&#x9;&#x9;&#x9;&#x9;= B.DATA_NASCIMENTO&#xA; ,GENERO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= UPPER(B.GENERO)&#xA; ,ENROLL&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.ENROLL&#xA; ,STATUS&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.STATUS&#xA; ,EMAIL&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.EMAIL&#xA; ,TEL_RESIDENCIAL&#x9;&#x9;&#x9;&#x9;= DB_TCLSEMP.[dbo].[FN_REMOVE_TEXTO](B.TEL_RESIDENCIAL)&#xA; ,TEL_CELULAR&#x9;&#x9;&#x9;&#x9;&#x9;= DB_TCLSEMP.[dbo].[FN_REMOVE_TEXTO](B.TEL_CELULAR)&#xA; ,CEP&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.CEP&#xA; ,RUA&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.RUA&#xA; ,NUMERO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.NUMERO&#xA; ,COMPLEMENTO&#x9;&#x9;&#x9;&#x9;&#x9;= B.COMPLEMENTO&#xA; ,BAIRRO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.BAIRRO&#xA; ,CIDADE&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.CIDADE&#xA; ,ESTADO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;= B.ESTADO&#xA; ,DATA_ACEITE_REGULAMENTO&#x9;&#x9;= B.DATA_ACEITE_REGULAMENTO&#xA; ,DATA_VERIFICACAO_EMAIL&#x9;&#x9;= B.DATA_VERIFICACAO_EMAIL&#xA; ,DATA_DELETE_USUARIO&#x9;&#x9;&#x9;= B.DATA_DELETE_USUARIO&#xA; ,DATA_CRIACAO_PARTICIPANTE&#x9;&#x9;= B.DATA_CRIACAO_PARTICIPANTE&#xA; ,DATA_ATUALIZACAO_PARTICIPANTE = B.DATA_ATUALIZACAO_PARTICIPANTE&#xA; ,DATA_INATIVACAO_PARTICIPANTE_API = B.DATA_INATIVACAO_PARTICIPANTE_API&#xA;FROM&#xA; DB_SAFRA.DBO.TB_PARTICIPANTES A&#xA; INNER JOIN DB_SAFRA.DBO.TB_PARTICIPANTES_TEMP B (NOLOCK)&#xA;  ON A.ID_PARTICIPANTE = B.ID_PARTICIPANTE" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
