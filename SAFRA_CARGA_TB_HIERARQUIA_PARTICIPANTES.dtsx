                  <outputColumns>
                    <outputColumn
                      refId="Package\Carrega TEMP\Recupera Valores.Outputs[ADO NET Source Output].Columns[id_participante]"
                      dataType="nText"
                      errorOrTruncationOperation="Conversion"
                      errorRowDisposition="FailComponent"
                      externalMetadataColumnId="Package\Carrega TEMP\Recupera Valores.Outputs[ADO NET Source Output].ExternalColumns[id_participante]"
