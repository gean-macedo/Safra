                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT HPT.*
		FROM DBO.TB_HIERARQUIA_PARTICIPANTES_TEMP AS HPT (NOLOCK)
LEFT JOIN DBO.TB_PARTICIPANTES										AS PA (NOLOCK)
		ON HPT.id_participante = PA.ID_PARTICIPANTE
		WHERE NOT EXISTS (
		SELECT 1 FROM DBO.TB_HIERARQUIA_PARTICIPANTES AS HP (NOLOCK)
		WHERE HPT.id_participante = HP.ID_PARTICIPANTE)</property>
