            <component
              refId="Package\Carrega TEMP\Recupera Valores"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;4"
              description="Consumes data from SQL Server, OLE DB, ODBC, or Oracle, using the corresponding .NET Framework data provider. Use a Transact-SQL statement to define the result set. For example, extract data from SQL Server with the .NET Framework data provider for SQL Server."
              name="Recupera Valores"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement used by the component to extract data."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select 
	pa.id::text 									as id_participante
	,pa.user_id										as id_usuario
	,pa."name" 										as nome
	,pa.rg
	,replace(replace(pa.cpf,'.',''),'-','')			as cpf
	,CASE 
    WHEN LENGTH(birthdate) = 8 AND birthdate ~ '^\d{8}$' AND birthdate NOT LIKE '30%02%' THEN 
        TO_CHAR(TO_DATE(birthdate, 'DDMMYYYY'), 'YYYY-MM-DD')
    WHEN LENGTH(birthdate) = 8 AND birthdate ~ '^\d{2}-\d{2}-\d{2}$' THEN 
        '19' || LEFT(birthdate, 2) || '-' || 
        SUBSTRING(birthdate, 4, 2) || '-' || 
        RIGHT(birthdate, 2)
    when LENGTH(birthdate) not in (8, 10) or
    (birthdate !~ '^\d{4}-\d{2}-\d{2}$' and birthdate &lt;&gt; '0')
    or birthdate LIKE '30%02%'
    then NULL
    ELSE 
        birthdate
    end as data_nascimento
	,pa.gender 											as genero
	,pa.enroll
	,case
		when pa.status = 0 then 'Inativo'
		when pa.status = 1 then 'Ativo'
		when pa.status = 2 then 'Pre-cadastro'
		when pa.status = 3 then 'Bloqueado'
		when pa.status = 4 then 'Verificar'
		when pa.status = 5 then 'Aguardando Aprovação'
		when pa.status = 6 then 'Catálogo'
		else '&lt;INDEFINIDO&gt;'
	end													as status
    ,coalesce(ce.data, u.email) 						as email
    ,ctr.data                   						as tel_residencial
    ,ctc.data                   						as tel_celular
    ,replace(pd.zip,'-','')             				as cep
    ,pd.street                  						as rua
    ,pd.number                  						as numero
    ,pd.complement              						as complemento
    ,pd.neighborhood            						as bairro
    ,ci.name                    						as cidade
    ,st.name                    						as estado
    ,dar.data_aceite_regulamento
    ,u.email_verified_at 						as data_verificacao_email
    ,u.deleted_at 								as data_delete_usuario
    ,pa.created_at								as data_criacao_participante
    ,pa.updated_at								as data_atualizacao_participante
    ,case when pa.status = 0 and pa.updated_by = 'beb6b98c-f415-4bf7-9436-ad0cb2f451bf'
    	then pa.updated_at
    	end 									as data_inativacao_participante_api
from
	safra_api_vendavall_20240828225002.participants pa
	left join safra_api_vendavall_20240828225002.users u
		on pa.user_id = u.id
	left join safra_api_vendavall_20240828225002.contacts ce
    	on (ce.contactable_type = 'App\Models\Tenant\Participant'
    	and ce.type = 1
    	and ce.contactable_id = pa.id)
    left join safra_api_vendavall_20240828225002.contacts ctr
        on (ctr.contactable_type = 'App\Models\Tenant\Participant'
        and ctr.type = 0
        and ctr.contactable_id = pa.id)
    left join safra_api_vendavall_20240828225002.contacts ctc
        on (ctc.contactable_type = 'App\Models\Tenant\Participant'
        and ctc.type = 2
        and ctc.contactable_id = pa.id)
    left join safra_api_vendavall_20240828225002.participant_addresses pd
        on (pa.id = pd.participant_id)
    left join safra_api_vendavall_20240828225002.cities ci
        on (pd.city_id = ci.id)
    left join safra_api_vendavall_20240828225002.states st
    	on (pd.state_id = st.id)
	left join (
		select 
			row_number() over(partition by prt.participant_id,prt.rule_and_term_id,prt.campaign_id order by  prt.participant_id,prt.rule_and_term_id,prt.campaign_id,prt.created_at asc ) repet
			,count(*)  over(partition by prt.participant_id,prt.rule_and_term_id,prt.campaign_id order by  prt.participant_id,prt.rule_and_term_id,prt.campaign_id ) repet_total
			,rt.slug
			,prt.created_at as data_aceite_regulamento
			,prt.participant_id
			,prt.rule_and_term_id
			,prt.campaign_id
		from safra_api_vendavall_20240828225002.participant_rule_and_term prt
			join safra_api_vendavall_20240828225002.rule_and_terms rt on (rt.id = prt.rule_and_term_id)
		where 
			rt.slug = 'regulamento'
	) dar on pa.id = dar.participant_id	and dar.repet = 1
where
	coalesce(ce.data, u.email) not like '%markup%'
and pa.name not like '%TESTE%'</property>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">300</property>
                <property
                  dataType="System.Boolean"
                  description="Indicates whether to allow non-string external columns to be implicitly converted to strings at the output columns."
                  name="AllowImplicitStringConversion">true</property>
                <property
                  dataType="System.String"
                  description="The Source database table name."
                  expressionType="Notify"
                  name="TableOrViewName"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor"></property>
                <property
                  dataType="System.Int32"
                  description="Specify the mode to retrieve external column information"
                  name="AccessMode"
                  typeConverter="Microsoft.SqlServer.Dts.Pipeline.DataReaderSourceAdapter+EnumToStringConverter">2</property>
                <property
                  dataType="System.String"
                  name="UserComponentTypeName">Microsoft.DataReaderSourceAdapter</property>
              </properties>
              <connections>
                <connection
                  refId="Package\Carrega TEMP\Recupera Valores.Connections[IDbConnection]"
                  connectionManagerID="Package.ConnectionManagers[vendavall40 - PROD REP]"
