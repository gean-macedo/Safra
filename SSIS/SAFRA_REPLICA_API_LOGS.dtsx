              <properties>
                <property
                  dataType="System.String"
                  description="Especifica a instrução SQL usada pelo componente para extrair os dados."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT id::text as job_id
, job_name
, transaction_id::text
, success_count
, error_count
, status
, executed_at
, created_at
, updated_at
FROM public.job_logs
WHERE 
    updated_at::date BETWEEN (now() - INTERVAL '10 day')::date AND now()::date
    OR created_at::date BETWEEN (now() - INTERVAL '10 day')::date AND now()::date</property>
                <property
