                  description="O nome da tabela de banco de dados de Origem."
                  expressionType="Notify"
                  name="TableOrViewName"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">"safra_api_vendavall_20240805110525"."participants"</property>
                <property
