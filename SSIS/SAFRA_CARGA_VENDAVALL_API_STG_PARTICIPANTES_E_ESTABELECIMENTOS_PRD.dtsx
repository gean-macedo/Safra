            <SQLTask:SqlTaskData
              SQLTask:Connection="{A703AD22-226F-4704-8E03-1A3BEB881215}"
              SQLTask:SqlStatementSource="   DELETE FROM safra_api_vendavall_20240828225002.participant_rule_and_term&#xA;WHERE participant_id IN (&#xA;    SELECT prt.participant_id&#xA;    FROM safra_api_vendavall_20240828225002.participant_rule_and_term AS prt&#xA;    INNER JOIN safra_api_vendavall_20240828225002.participants AS p&#xA;        ON prt.participant_id = p.id&#xA;    WHERE &#xA;        p.CPF = ? &#xA;        AND ? = 'Pré-Update DLQ' --status&#xA;        AND ? = 4  -- Have Points&#xA;        AND p.status NOT IN (0, 3, 6)&#xA;);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::CPF"
