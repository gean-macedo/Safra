              <properties>
                <property
                  dataType="System.String"
                  description="Especifica a instrução SQL usada pelo componente para extrair os dados."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT p.cpf
	,e.cnpj
	,peu.participant_id 
	,peu.establishment_id 
FROM public.participants_establishments_unlink peu
inner join public.participants p 
on p.id = peu.participant_id 
inner join public.establishments e 
on e.id = peu.establishment_id 
where peu.deleted_at is null;</property>
