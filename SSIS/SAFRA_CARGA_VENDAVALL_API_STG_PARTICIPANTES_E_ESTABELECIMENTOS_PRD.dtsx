        <SQLTask:SqlTaskData
          SQLTask:Connection="{61F8E1B6-FB90-45F9-A2C8-9A2227760C21}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE [dbo].[TB_PARTICIPANTES_API]&#xA;TRUNCATE TABLE [dbo].[TB_PARTICIPANTES_STG]&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
