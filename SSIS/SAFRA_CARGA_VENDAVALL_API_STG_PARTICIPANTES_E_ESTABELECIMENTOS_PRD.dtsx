            <SQLTask:SqlTaskData
              SQLTask:Connection="{A703AD22-226F-4704-8E03-1A3BEB881215}"
              SQLTask:SqlStatementSource="-- PROD - INSERT&#xA;WITH max_id_cte AS (&#xA;    SELECT COALESCE(MAX(id), 0) AS max_id&#xA;    FROM safra_api_vendavall_20240828225002.participant_rule_and_term_history&#xA;),&#xA;dados AS (&#xA;    SELECT&#xA;        row_number() OVER () + max_id_cte.max_id AS id,&#xA;        prt.participant_id,&#xA;        prt.rule_and_term_id,&#xA;        prt.campaign_id,&#xA;        'Site' AS table_type,&#xA;        'beb6b98c-f415-4bf7-9436-ad0cb2f451bf' AS created_by,&#xA;        now() AS history_created_at,&#xA;        prt.created_at,&#xA;        prt.updated_at&#xA;    FROM safra_api_vendavall_20240828225002.participant_rule_and_term AS prt&#xA;    INNER JOIN safra_api_vendavall_20240828225002.participants AS p&#xA;        ON prt.participant_id = p.id&#xA;    CROSS JOIN max_id_cte&#xA;    WHERE &#xA;        p.CPF = ? -- cpf&#xA;        AND ? = 'Pré-Update DLQ' --status&#xA;        AND ? = 4 --havepoins&#xA;        AND p.status NOT IN (0, 3, 6)&#xA;)&#xA;&#xA;INSERT INTO safra_api_vendavall_20240828225002.participant_rule_and_term_history &#xA;    (id, participant_id, rule_and_term_id, campaign_id, table_type, created_by, history_created_at, created_at, updated_at)&#xA;SELECT &#xA;    id,&#xA;    participant_id,&#xA;    rule_and_term_id,&#xA;    campaign_id,&#xA;    table_type,&#xA;    created_by,&#xA;    history_created_at,&#xA;    created_at,&#xA;    updated_at&#xA;FROM dados;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::CPF"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="16"
                SQLTask:ParameterSize="-1" />
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::STATUS"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="16"
                SQLTask:ParameterSize="-1" />
              <SQLTask:ParameterBinding
                SQLTask:ParameterName="0"
                SQLTask:DtsVariableName="User::HAVE_POINTS"
                SQLTask:ParameterDirection="Input"
                SQLTask:DataType="11"
                SQLTask:ParameterSize="-1" />
