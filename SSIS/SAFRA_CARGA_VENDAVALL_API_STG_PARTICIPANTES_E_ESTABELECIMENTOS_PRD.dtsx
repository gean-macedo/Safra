    <DTS:Executable
      DTS:refId="Package\Update &quot;Inativar Estabelecimento&quot; e &quot;Unlink&quot;"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarefa Executar SQL"
      DTS:DTSID="{F4E33516-024E-4142-ABD9-F8A61B8E34E7}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Update &quot;Inativar Estabelecimento&quot; e &quot;Unlink&quot;"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{61F8E1B6-FB90-45F9-A2C8-9A2227760C21}"
          SQLTask:SqlStatementSource="WITH VINCULO_UNICO AS (&#xA;    SELECT&#xA;        PA.CPF&#xA;    FROM TB_PARTICIPANTES_API PA (NOLOCK)&#xA;&#xA;    INNER JOIN TB_ESTABELECIMENTOS_PARTICIPANTES_API EPA (NOLOCK)&#xA;        ON EPA.CPF = PA.CPF&#xA;        AND EPA.STATUS = 'Inativar'&#xA;&#xA;    INNER JOIN TB_ESTABELECIMENTOS_STG EA (NOLOCK)&#xA;        ON EA.cnpj = EPA.CNPJ&#xA;&#xA;    INNER JOIN TB_PARTICIPANTES_STG PS (NOLOCK)&#xA;        ON PS.CPF = PA.CPF&#xA;&#xA;    INNER JOIN TB_ESTABELECIMENTOS_PARTICIPANTES_STG EPS (NOLOCK)&#xA;        ON EPS.participant_id = PS.id&#xA;        AND EPS.establishment_id = EA.id&#xA;&#xA;    WHERE NOT EXISTS (&#xA;        SELECT 1&#xA;        FROM TB_ESTABELECIMENTOS_PARTICIPANTES_STG EPS2 (NOLOCK)&#xA;        INNER JOIN TB_ESTABELECIMENTOS_STG EA2 (NOLOCK)&#xA;            ON EA2.id = EPS2.establishment_id&#xA;        WHERE EPS2.participant_id = PS.id&#xA;          AND EA2.id &lt;&gt; EA.id -- outro estabelecimento ativo&#xA;    )&#xA;    GROUP BY PA.CPF&#xA;)&#xA;UPDATE PA&#xA;SET &#xA;    PA.STATUS = 'Pré-Update DLQ',&#xA;    PA.HAVE_POINTS = CASE &#xA;                         WHEN PA.HAVE_POINTS = 0 THEN 4&#xA;                         WHEN PA.HAVE_POINTS = 1 THEN 5&#xA;                         ELSE 4&#xA;                     END&#xA;FROM TB_PARTICIPANTES_API PA&#xA;INNER JOIN VINCULO_UNICO VU&#xA;    ON VU.CPF = PA.CPF;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Verifica Estabelecimentos Existentes"
