                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="O comando SQL a ser executado."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DISTINCT CNPJ
	,PA.ID AS ID_ESTABELECIMENTO
	,UPPER(name) AS NOME
	,RESALE_CODE
	,ADDITIONAL_INFO
,PA.STATUS
FROM TB_ESTABELECIMENTOS_API AS PA (NOLOCK)
WHERE
	NOT EXISTS (
		SELECT
			NULL
		FROM
			DBO.TB_ESTABELECIMENTOS_STG AS PS (NOLOCK)
		WHERE
			PS.CNPJ = PA.CNPJ)
AND PA.STATUS = 'PRÉ-APROVADO DLQ'</property>
