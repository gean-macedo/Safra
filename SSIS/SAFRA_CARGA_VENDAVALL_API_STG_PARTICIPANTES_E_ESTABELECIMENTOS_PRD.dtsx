            <SQLTask:SqlTaskData
              SQLTask:Connection="{A703AD22-226F-4704-8E03-1A3BEB881215}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="WITH inserted_user AS (&#xA;    INSERT INTO safra_api_vendavall_20240828225002.users (&#xA;        id,&#xA;        username,&#xA;        email,&#xA;        email_verified_at,&#xA;        password,&#xA;        remember_token,&#xA;        created_at,&#xA;        updated_at,&#xA;        deleted_at,&#xA;        created_by,&#xA;        updated_by&#xA;    )&#xA;&#x9;VALUES&#xA;        (&#xA;            gen_random_uuid(),&#xA;            ?, --CPF&#xA;            ?, --EMAIL&#xA;            NULL,&#xA;            '$2y$10$WEhzhUJ7AWM1pWFvyCmIG.XT3KQDw75iy6CoLQPp/.4yHGogmqyyW',&#xA;            NULL,&#xA;            now(),&#xA;            NULL,&#xA;            NULL,&#xA;            'beb6b98c-f415-4bf7-9436-ad0cb2f451bf',&#xA;            NULL&#xA;        )&#xA;    RETURNING id AS user_id&#xA;),&#xA;inserted_participant AS (&#xA;    INSERT INTO safra_api_vendavall_20240828225002.participants (&#xA;        id,&#xA;        name,&#xA;        rg,&#xA;        cpf,&#xA;        birthdate,&#xA;        gender,&#xA;        enroll,&#xA;        status,&#xA;        user_id,&#xA;        participant_import_id,&#xA;        updated_by,&#xA;        created_by,&#xA;        deleted_at,&#xA;        created_at,&#xA;        updated_at,&#xA;        ideal_prize_registered&#xA;    )&#xA;    SELECT&#xA;        gen_random_uuid(),&#xA;        ?, --NOME&#xA;        NULL,&#xA;        ?, --CPF&#xA;        NULLIF(?, ''), --DT_ANIVERSARIO&#xA;        NULLIF(?, ''), --GENERO&#xA;        ?, --ENROLL&#xA;        ?, --COD_CARGO&#xA;        user_id,&#xA;        NULL,&#xA;        NULL,&#xA;        'beb6b98c-f415-4bf7-9436-ad0cb2f451bf',&#xA;        NULL,&#xA;        now(),&#xA;        NULL,&#xA;        false&#xA;    FROM inserted_user&#xA;    RETURNING id AS participant_id&#xA;),&#xA;inserted_contact_email AS (&#xA;    INSERT INTO safra_api_vendavall_20240828225002.contacts (&#xA;        id,&#xA;        contactable_type,&#xA;        contactable_id,&#xA;        type,&#xA;        data,&#xA;        updated_by,&#xA;        created_by,&#xA;        created_at,&#xA;        updated_at&#xA;    )&#xA;    SELECT&#xA;        gen_random_uuid(),&#xA;        'App\Models\Tenant\Participant',&#xA;        participant_id,&#xA;        1,&#xA;        ?, --EMAIL&#xA;        NULL,&#xA;        'beb6b98c-f415-4bf7-9436-ad0cb2f451bf',&#xA;        now(),&#xA;        NULL&#xA;    FROM inserted_participant&#xA;),&#xA;inserted_contact_phone AS (&#xA;    INSERT INTO safra_api_vendavall_20240828225002.contacts (&#xA;        id,&#xA;        contactable_type,&#xA;        contactable_id,&#xA;        type,&#xA;        data,&#xA;        updated_by,&#xA;        created_by,&#xA;        created_at,&#xA;        updated_at&#xA;    )&#xA;    SELECT&#xA;        gen_random_uuid(),&#xA;        'App\Models\Tenant\Participant',&#xA;        participant_id,&#xA;        2,&#xA;        ?, --TELEFONE&#xA;        NULL,&#xA;        'beb6b98c-f415-4bf7-9436-ad0cb2f451bf',&#xA;        now(),&#xA;        NULL&#xA;    FROM inserted_participant&#xA;),&#xA;inserted_contact_phone_fixo AS (&#xA;    INSERT INTO safra_api_vendavall_20240828225002.contacts (&#xA;        id,&#xA;        contactable_type,&#xA;        contactable_id,&#xA;        type,&#xA;        data,&#xA;        updated_by,&#xA;        created_by,&#xA;        created_at,&#xA;        updated_at&#xA;    )&#xA;    SELECT&#xA;        gen_random_uuid(),&#xA;        'App\Models\Tenant\Participant',&#xA;        participant_id,&#xA;        0,&#xA;        '(00) 0000-0000',&#xA;        NULL,&#xA;        'beb6b98c-f415-4bf7-9436-ad0cb2f451bf',&#xA;        now(),&#xA;        NULL&#xA;    FROM inserted_participant&#xA;),&#xA;inserted_program_participant AS (&#xA;    INSERT INTO safra_api_vendavall_20240828225002.program_participant (&#xA;        program_id,&#xA;        participant_id,&#xA;        updated_by,&#xA;        created_by,&#xA;        created_at,&#xA;        updated_at,&#xA;        company_position_id&#xA;    )&#xA;    SELECT&#xA;        '1b66ae61-17f5-41d0-baa7-8ebdd942c145',&#xA;        participant_id,&#xA;        NULL,&#xA;        'beb6b98c-f415-4bf7-9436-ad0cb2f451bf',&#xA;        now(),&#xA;        NULL,&#xA;        ? --CARGO&#xA;    FROM inserted_participant&#xA;)&#xA;SELECT participant_id FROM inserted_participant;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
