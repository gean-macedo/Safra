                  description="Especifica a variável que contém o nome do objeto de banco de dados usado para abrir um conjunto de linhas."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="O comando SQL a ser executado."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH VINCULOS AS (
    SELECT PS.ID AS ID_PARTICIPANTE
		,PS.CPF
		,COUNT(EPS.establishment_id) AS QTD
    FROM TB_PARTICIPANTES_STG AS PS (NOLOCK)
    INNER JOIN TB_ESTABELECIMENTOS_PARTICIPANTES_STG AS EPS (NOLOCK)
        ON EPS.participant_id = PS.id
    GROUP BY PS.ID, PS.CPF
)
SELECT 
	PS.ID AS ID_PARTICIPANTE
	,ES.ID AS ID_ESTABELECIMENTO
FROM [dbo].[TB_ESTABELECIMENTOS_PARTICIPANTES_UNLINK_API] AS UA (NOLOCK)
INNER JOIN DBO.TB_PARTICIPANTES_STG AS PS (NOLOCK)
	ON PS.cpf = UA.CPF
INNER JOIN DBO.TB_ESTABELECIMENTOS_STG AS ES (NOLOCK)
	ON ES.cnpj = UA.CNPJ
INNER JOIN DBO.TB_ESTABELECIMENTOS_PARTICIPANTES_STG AS EPS (NOLOCK)
	ON PS.id = EPS.participant_id 
	AND ES.id = EPS.establishment_id
INNER JOIN VINCULOS V 
	ON V.CPF = UA.CPF</property>
