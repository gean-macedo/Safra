    <DTS:Executable
      DTS:refId="Package\Verifica NOVO EXTRATO DE VENDAS"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Tarefa Executar SQL"
      DTS:DTSID="{81E7E7CE-2B8F-45D6-B589-253DB513ED53}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Verifica NOVO EXTRATO DE VENDAS"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2022; © 2022 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9D4E814F-EA3B-430C-AA83-6FA4CA0F6176}"
          SQLTask:SqlStatementSource="&#xA;SELECT COUNT(1) AS RWCOUNT&#xA;  FROM dbo.TB_EXTRATO_VENDAS_TEMP AS ET (NOLOCK)&#xA;  WHERE NOT EXISTS (&#xA;&#x9;&#x9;&#x9;SELECT NULL&#xA;&#x9;&#x9;&#x9;FROM DBO.TB_EXTRATO_VENDAS AS E (NOLOCK)&#xA;&#x9;&#x9;&#x9;WHERE E.CNPJ_STORE = ET.CNPJ_STORE&#xA;&#x9;&#x9;&#x9;AND E.QNTY = ET.QNTY&#xA;&#x9;&#x9;&#x9;AND E.ITEM_VALUE = ET.ITEM_VALUE&#xA;&#x9;&#x9;&#x9;AND&#x9;E.ITEM_VALUE_TOTAL = ET.ITEM_VALUE_TOTAL&#xA;&#x9;&#x9;&#x9;AND&#x9;E.SALE_DATE&#x9;= ET.SALE_DATE&#xA;&#x9;&#x9;&#x9;AND&#x9;E.NF_NUMBER&#x9;= ET.NF_NUMBER&#xA;&#x9;&#x9;&#x9;AND&#x9;E.PRODUCT_ID = ET.PRODUCT_ID&#xA;&#x9;&#x9;&#x9;AND&#x9;E.SALER_CPF&#x9;= ET.SALER_CPF&#xA;&#x9;&#x9;&#x9;AND&#x9;E.COMPANY_POSITION = ET.COMPANY_POSITION&#xA;&#x9;&#x9;&#x9;)"
          SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
          <SQLTask:ResultBinding
            SQLTask:ResultName="0"
            SQLTask:DtsVariableName="User::RWCOUNT" />
        </SQLTask:SqlTaskData>
      </DTS:ObjectData>
