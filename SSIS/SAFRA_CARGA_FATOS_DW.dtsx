    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{4D3AAE08-1DB2-414C-AE60-D30BD4E8631D}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @DAT_INI VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_INI] +&#xA;&quot;DECLARE @DAT_FIM VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_FIM] + &quot;;&#xA;&#xA;SELECT&#xA;&#x9;PA.ID_PARTICIPANTE&#xA;&#x9;,CAST(CONCAT(HP.ID_VERSAO, '-',PA.ID_PARTICIPANTE) AS NTEXT)&#x9;&#x9;AS CHAVE_PARTICIPANTE&#xA;&#x9;,VISITED_PAGE&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS PAGINA&#xA;&#x9;,CASE &#xA;&#x9;&#x9;WHEN AV.BROWSER LIKE '%iPHONE%' OR AV.BROWSER LIKE '%Android%'&#xA;&#x9;&#x9;THEN 'MOBILE'&#xA;&#x9;&#x9;ELSE 'DESKTOP'&#xA;&#x9;END AS TIPO_ACESSO&#xA;&#x9;,CAST(DATE_TIME AS DATE)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DATA_ACESSO&#xA;    ,CONVERT(VARCHAR(8), DATE_TIME, 108)&#x9;&#x9;&#x9;&#x9;AS HORA_ACESSO&#xA;FROM&#xA;&#x9;[DB_VENDAVALL4].[dbo].[TB_ACESSOS_VENDAVALL]&#x9;&#x9;AS AV (NOLOCK)&#xA;&#x9;INNER JOIN [dbo].[TB_PARTICIPANTES]&#x9;AS TP (NOLOCK)&#xA;&#x9;&#x9;ON AV.USER_ID = TP.ID_USUARIO&#xA;&#x9;INNER JOIN dbo.D_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS PA (NOLOCK)&#xA;&#x9;&#x9;ON TP.ID = PA.ID_PARTICIPANTE&#xA;&#x9;INNER JOIN dbo.TB_HIERARQUIA_PARTICIPANTES&#x9;&#x9;&#x9;AS HP (NOLOCK)&#xA;&#x9;&#x9;ON TP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND CAST(AV.DATE_TIME AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )&#xA;WHERE&#xA;&#x9;AV.CLIENTE = 'SAFRA'&#xA;&#x9;AND PA.ID_CARGO &lt;&gt; 1 --Tira o cargo Trade&#xA;&#x9;AND CAST(DATE_TIME AS DATE) BETWEEN @DAT_INI AND @DAT_FIM&#xA;&#x9;&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="RESULT_SETS_ACESSOS">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE @DAT_INI VARCHAR(20)		= '2026-04-26'DECLARE @DAT_FIM VARCHAR(20)		= '2026-06-25';

SELECT
	PA.ID_PARTICIPANTE
	,CAST(CONCAT(HP.ID_VERSAO, '-',PA.ID_PARTICIPANTE) AS NTEXT)		AS CHAVE_PARTICIPANTE
	,VISITED_PAGE										AS PAGINA
	,CASE 
		WHEN AV.BROWSER LIKE '%iPHONE%' OR AV.BROWSER LIKE '%Android%'
		THEN 'MOBILE'
		ELSE 'DESKTOP'
	END AS TIPO_ACESSO
	,CAST(DATE_TIME AS DATE)							AS DATA_ACESSO
    ,CONVERT(VARCHAR(8), DATE_TIME, 108)				AS HORA_ACESSO
FROM
	[DB_VENDAVALL4].[dbo].[TB_ACESSOS_VENDAVALL]		AS AV (NOLOCK)
	INNER JOIN [dbo].[TB_PARTICIPANTES]	AS TP (NOLOCK)
		ON AV.USER_ID = TP.ID_USUARIO
	INNER JOIN dbo.D_PARTICIPANTES						AS PA (NOLOCK)
		ON TP.ID = PA.ID_PARTICIPANTE
	INNER JOIN dbo.TB_HIERARQUIA_PARTICIPANTES			AS HP (NOLOCK)
		ON TP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(AV.DATE_TIME AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )
WHERE
	AV.CLIENTE = 'SAFRA'
	AND PA.ID_CARGO &lt;&gt; 1 --Tira o cargo Trade
	AND CAST(DATE_TIME AS DATE) BETWEEN @DAT_INI AND @DAT_FIM
	</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{9F261A3D-F538-4CD9-970A-ED6996387772}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @ID_CAMPANHA INT&#x9;= &quot; + (DT_WSTR, 12) @[User::ID_CAMPANHA] +&#xA;&quot;DECLARE @DAT_INI VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_INI] +&#xA;&quot;DECLARE @DAT_FIM VARCHAR(20)&#x9;&#x9;= (SELECT MAX(DATA_EXPIRACAO) FROM [DB_PREMIOIDEAL].[DBO].[TB_PONTOS] (NOLOCK)&#xA;WHERE ID_CAMPANHA = @ID_CAMPANHA);&#xA;&#xA;WITH CREDITOS AS(&#xA;SELECT&#xA;&#x9;CAST(PC.DATA_CREDITO AS DATE)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DATA&#xA;&#x9;,DP.ID&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ID_PARTICIPANTE&#xA;&#x9;,CAST(CONCAT(HP.ID_VERSAO, '-',DP.ID) AS NVARCHAR(MAX))&#x9;&#x9;AS CHAVE_PARTICIPANTE&#xA;&#x9;,TIPO_CREDITO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CATEGORIA&#xA;&#x9;,SUM(PONTOS_CREDITADOS)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CREDITOS&#xA;&#x9;,SUM(REAIS_CREDITADOS)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CREDITOS_REAIS&#xA;&#x9;,SUM(SALDO_PONTOS)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS SALDO&#xA;&#x9;,SUM(SALDO_REAIS)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS SALDO_REAIS&#xA;FROM&#xA;&#x9;[DB_PREMIOIDEAL].[DBO].[TB_PONTOS]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS PC (NOLOCK)&#xA;&#x9;LEFT JOIN [DB_PREMIOIDEAL].[DBO].[TB_PARTICIPANTES]&#x9;&#x9;&#x9;AS PA (NOLOCK)&#xA;&#x9;&#x9;ON PC.ID_PARTICIPANTE = PA.ID_PARTICIPANTE&#xA;&#x9;LEFT JOIN DB_SAFRA.DBO.TB_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DP (NOLOCK)&#xA;&#x9;&#x9;ON PA.CPF = DP.CPF&#xA;&#x9;INNER JOIN DB_SAFRA.dbo.TB_HIERARQUIA_PARTICIPANTES&#x9;&#x9;&#x9;AS HP (NOLOCK)&#xA;&#x9;&#x9;ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND CAST(PC.DATA_CREDITO AS DATE) BETWEEN DATA_INICIO &#xA;&#x9;&#x9;AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE))&#xA;WHERE&#xA;&#x9;PC.ID_CAMPANHA = @ID_CAMPANHA&#xA;&#x9;--AND CAST(PC.DATA_CREDITO AS DATE) BETWEEN @DAT_INI AND @DAT_FIM&#xA;GROUP BY&#xA;&#x9;CAST(PC.DATA_CREDITO AS DATE)&#xA;&#x9;,DP.ID&#x9;&#xA;&#x9;,TIPO_CREDITO&#xA;&#x9;,HP.ID_VERSAO&#xA;),&#xA;&#xA;&#xA;VENCIMENTOS AS(&#xA;SELECT&#xA;&#x9;CAST(PC.DATA_EXPIRACAO AS DATE)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DATA&#xA;&#x9;,DP.ID&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ID_PARTICIPANTE&#xA;&#x9;,CAST(CONCAT(HP.ID_VERSAO, '-',DP.ID) AS NVARCHAR(MAX))&#x9;&#x9;AS CHAVE_PARTICIPANTE&#xA;&#x9;,TIPO_CREDITO&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CATEGORIA&#xA;&#x9;,NULL&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CREDITOS&#xA;&#x9;,NULL&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CREDITOS_REAIS&#xA;&#x9;,SUM(SALDO_PONTOS)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS VENCIMENTOS&#xA;&#x9;,SUM(SALDO_REAIS)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS VENCIMENTOS_REAIS&#xA;FROM&#xA;&#x9;[DB_PREMIOIDEAL].[DBO].[TB_PONTOS]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS PC (NOLOCK)&#xA;&#x9;LEFT JOIN [DB_PREMIOIDEAL].[DBO].[TB_PARTICIPANTES]&#x9;&#x9;&#x9;AS PA (NOLOCK)&#xA;&#x9;&#x9;ON PC.ID_PARTICIPANTE = PA.ID_PARTICIPANTE&#xA;&#x9;LEFT JOIN DB_SAFRA.DBO.TB_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DP (NOLOCK)&#xA;&#x9;&#x9;ON PA.CPF = DP.CPF&#xA;&#x9;INNER JOIN DB_SAFRA.dbo.TB_HIERARQUIA_PARTICIPANTES&#x9;&#x9;&#x9;AS HP (NOLOCK)&#xA;&#x9;&#x9;ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND CAST(PC.DATA_EXPIRACAO AS DATE) BETWEEN DATA_INICIO &#xA;&#x9;&#x9;AND ISNULL(DATA_FIM, @DAT_FIM)&#xA;WHERE&#xA;&#x9;PC.ID_CAMPANHA = @ID_CAMPANHA&#xA;&#x9;--AND CAST(PC.DATA_EXPIRACAO AS DATE) BETWEEN @DAT_INI AND @DAT_FIM&#xA;GROUP BY&#xA;&#x9;CAST(PC.DATA_EXPIRACAO AS DATE)&#xA;&#x9;,DP.ID&#x9;&#xA;&#x9;,TIPO_CREDITO&#xA;&#x9;,HP.ID_VERSAO&#xA;),&#xA;&#xA;PONTOS AS(&#xA;SELECT&#xA;&#x9;*&#xA;&#x9;,'CREDITOS'&#x9;AS TIPO&#xA;FROM&#xA;&#x9;CREDITOS&#xA;&#xA;UNION ALL&#xA;&#xA;SELECT&#xA;&#x9;*&#xA;&#x9;,'VENCIMENTOS'&#x9;AS TIPO&#xA;FROM&#xA;&#x9;VENCIMENTOS&#xA;)&#xA;&#xA;&#xA;SELECT&#xA;&#x9;DD.DAT_DIA&#xA;&#x9;,PT.ID_PARTICIPANTE&#xA;&#x9;,PT.CHAVE_PARTICIPANTE&#xA;&#x9;,CATEGORIA&#xA;&#x9;,SUM(IIF(PT.TIPO = 'CREDITOS', PT.CREDITOS, 0))&#x9;&#x9;&#x9;AS CREDITOS&#xA;&#x9;,SUM(IIF(PT.TIPO = 'CREDITOS', PT.CREDITOS_REAIS, 0))&#x9;AS CREDITOS_REAIS&#xA;&#x9;,SUM(IIF(PT.TIPO = 'CREDITOS', PT.SALDO, 0))&#x9;&#x9;&#x9;AS SALDO&#xA;&#x9;,SUM(IIF(PT.TIPO = 'CREDITOS', PT.SALDO_REAIS, 0))&#x9;&#x9;AS SALDO_REAIS&#xA;&#x9;,SUM(IIF(PT.TIPO = 'VENCIMENTOS', PT.SALDO, 0))&#x9;&#x9;&#x9;AS VENCIMENTOS&#xA;&#x9;,SUM(IIF(PT.TIPO = 'VENCIMENTOS', PT.SALDO_REAIS, 0))&#x9;AS VENCIMENTOS_REAIS&#xA;FROM&#xA;&#x9;DB_MARKUP.MKP.D_DATAS&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DD (NOLOCK)&#xA;&#x9;INNER JOIN PONTOS&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS PT&#xA;&#x9;&#x9;ON PT.DATA = DD.DAT_DIA&#xA;GROUP BY&#xA;&#x9;DD.DAT_DIA&#xA;&#x9;,PT.ID_PARTICIPANTE&#xA;&#x9;,PT.CHAVE_PARTICIPANTE&#xA;&#x9;,CATEGORIA&#xA;ORDER BY&#xA;&#x9;1&#xA;&#x9;&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="RESULT_SETS_CREDITOS">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE @ID_CAMPANHA INT	= 375DECLARE @DAT_INI VARCHAR(20)		= '2026-04-26'DECLARE @DAT_FIM VARCHAR(20)		= (SELECT MAX(DATA_EXPIRACAO) FROM [DB_PREMIOIDEAL].[DBO].[TB_PONTOS] (NOLOCK)
WHERE ID_CAMPANHA = @ID_CAMPANHA);

WITH CREDITOS AS(
SELECT
	CAST(PC.DATA_CREDITO AS DATE)								AS DATA
	,DP.ID														AS ID_PARTICIPANTE
	,CAST(CONCAT(HP.ID_VERSAO, '-',DP.ID) AS NVARCHAR(MAX))		AS CHAVE_PARTICIPANTE
	,TIPO_CREDITO												AS CATEGORIA
	,SUM(PONTOS_CREDITADOS)										AS CREDITOS
	,SUM(REAIS_CREDITADOS)										AS CREDITOS_REAIS
	,SUM(SALDO_PONTOS)											AS SALDO
	,SUM(SALDO_REAIS)											AS SALDO_REAIS
FROM
	[DB_PREMIOIDEAL].[DBO].[TB_PONTOS]							AS PC (NOLOCK)
	LEFT JOIN [DB_PREMIOIDEAL].[DBO].[TB_PARTICIPANTES]			AS PA (NOLOCK)
		ON PC.ID_PARTICIPANTE = PA.ID_PARTICIPANTE
	LEFT JOIN DB_SAFRA.DBO.TB_PARTICIPANTES						AS DP (NOLOCK)
		ON PA.CPF = DP.CPF
	INNER JOIN DB_SAFRA.dbo.TB_HIERARQUIA_PARTICIPANTES			AS HP (NOLOCK)
		ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(PC.DATA_CREDITO AS DATE) BETWEEN DATA_INICIO 
		AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE))
WHERE
	PC.ID_CAMPANHA = @ID_CAMPANHA
	--AND CAST(PC.DATA_CREDITO AS DATE) BETWEEN @DAT_INI AND @DAT_FIM
GROUP BY
	CAST(PC.DATA_CREDITO AS DATE)
	,DP.ID	
	,TIPO_CREDITO
	,HP.ID_VERSAO
),


VENCIMENTOS AS(
SELECT
	CAST(PC.DATA_EXPIRACAO AS DATE)								AS DATA
	,DP.ID														AS ID_PARTICIPANTE
	,CAST(CONCAT(HP.ID_VERSAO, '-',DP.ID) AS NVARCHAR(MAX))		AS CHAVE_PARTICIPANTE
	,TIPO_CREDITO												AS CATEGORIA
	,NULL														AS CREDITOS
	,NULL														AS CREDITOS_REAIS
	,SUM(SALDO_PONTOS)											AS VENCIMENTOS
	,SUM(SALDO_REAIS)											AS VENCIMENTOS_REAIS
FROM
	[DB_PREMIOIDEAL].[DBO].[TB_PONTOS]							AS PC (NOLOCK)
	LEFT JOIN [DB_PREMIOIDEAL].[DBO].[TB_PARTICIPANTES]			AS PA (NOLOCK)
		ON PC.ID_PARTICIPANTE = PA.ID_PARTICIPANTE
	LEFT JOIN DB_SAFRA.DBO.TB_PARTICIPANTES						AS DP (NOLOCK)
		ON PA.CPF = DP.CPF
	INNER JOIN DB_SAFRA.dbo.TB_HIERARQUIA_PARTICIPANTES			AS HP (NOLOCK)
		ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(PC.DATA_EXPIRACAO AS DATE) BETWEEN DATA_INICIO 
		AND ISNULL(DATA_FIM, @DAT_FIM)
WHERE
	PC.ID_CAMPANHA = @ID_CAMPANHA
	--AND CAST(PC.DATA_EXPIRACAO AS DATE) BETWEEN @DAT_INI AND @DAT_FIM
GROUP BY
	CAST(PC.DATA_EXPIRACAO AS DATE)
	,DP.ID	
	,TIPO_CREDITO
	,HP.ID_VERSAO
),

PONTOS AS(
SELECT
	*
	,'CREDITOS'	AS TIPO
FROM
	CREDITOS

UNION ALL

SELECT
	*
	,'VENCIMENTOS'	AS TIPO
FROM
	VENCIMENTOS
)


SELECT
	DD.DAT_DIA
	,PT.ID_PARTICIPANTE
	,PT.CHAVE_PARTICIPANTE
	,CATEGORIA
	,SUM(IIF(PT.TIPO = 'CREDITOS', PT.CREDITOS, 0))			AS CREDITOS
	,SUM(IIF(PT.TIPO = 'CREDITOS', PT.CREDITOS_REAIS, 0))	AS CREDITOS_REAIS
	,SUM(IIF(PT.TIPO = 'CREDITOS', PT.SALDO, 0))			AS SALDO
	,SUM(IIF(PT.TIPO = 'CREDITOS', PT.SALDO_REAIS, 0))		AS SALDO_REAIS
	,SUM(IIF(PT.TIPO = 'VENCIMENTOS', PT.SALDO, 0))			AS VENCIMENTOS
	,SUM(IIF(PT.TIPO = 'VENCIMENTOS', PT.SALDO_REAIS, 0))	AS VENCIMENTOS_REAIS
FROM
	DB_MARKUP.MKP.D_DATAS									AS DD (NOLOCK)
	INNER JOIN PONTOS										AS PT
		ON PT.DATA = DD.DAT_DIA
GROUP BY
	DD.DAT_DIA
	,PT.ID_PARTICIPANTE
	,PT.CHAVE_PARTICIPANTE
	,CATEGORIA
ORDER BY
	1
	</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{8F599320-4206-4443-8379-F2B214A95E3B}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @ID_CAMPANHA INT&#x9;= &quot; + (DT_WSTR, 12) @[User::ID_CAMPANHA] +&#xA;&quot;DECLARE @DAT_INI VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_INI] +&#xA;&quot;DECLARE @DAT_FIM VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_FIM] + &quot;;&#xA;&#xA;SELECT&#xA;&#x9;CAST(PC.DATA_RESGATE AS DATE)&#x9;&#x9;&#x9;AS DATA&#xA;&#x9;,DP.ID&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ID_PARTICIPANTE&#xA;&#x9;,CAST(CONCAT(HP.ID_VERSAO, '-',DP.ID) AS NVARCHAR(MAX))&#x9;&#x9;&#x9;&#x9;AS CHAVE_PARTICIPANTE&#xA;&#x9;,FORNECEDOR&#xA;&#x9;,CATEGORIA&#xA;&#x9;,PRODUTO&#xA;&#x9;,SUM(QUANTIDADE)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS QUANTIDADE&#xA;&#x9;,SUM(VALOR_RESGASTADO)&#x9;&#x9;&#x9;&#x9;&#x9;AS VALOR&#xA;FROM&#xA;&#x9;[DB_PREMIOIDEAL].[DBO].[TB_PONTOS_RESGATADOS]&#x9;&#x9;&#x9;&#x9;AS PC (NOLOCK)&#xA;&#x9;INNER JOIN DB_SAFRA.DBO.TB_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;AS DP (NOLOCK)&#xA;&#x9;&#x9;ON PC.CPF_PARTICIPANTE COLLATE SQL_LATIN1_GENERAL_CP1_CI_AS = DP.CPF&#xA;&#x9;--LEFT JOIN DB_SAFRA.dbo.TB_ESTABELECIMENTOS_PARTICIPANTES    AS EP (NOLOCK)&#xA;&#x9;--&#x9;ON EP.ID_PARTICIPANTE = DP.ID_PARTICIPANTE&#xA;&#x9;--LEFT JOIN DB_SAFRA.dbo.TB_ESTABELECIMENTOS&#x9;&#x9;&#x9;&#x9;&#x9;AS E (NOLOCK)&#xA;&#x9;--&#x9;ON E.ID_ESTABELECIMENTO = EP.ID_ESTABELECIMENTO&#xA;&#x9;INNER JOIN DB_SAFRA.dbo.TB_HIERARQUIA_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;AS HP (NOLOCK)&#xA;&#x9;&#x9;ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND CAST(PC.DATA_RESGATE AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )&#xA;WHERE&#xA;&#x9;ID_CAMPANHA = @ID_CAMPANHA&#xA;&#x9;AND CAST(PC.DATA_RESGATE AS DATE) BETWEEN @DAT_INI AND @DAT_FIM&#xA;GROUP BY&#xA;&#x9;CAST(PC.DATA_RESGATE AS DATE)&#xA;&#x9;,DP.ID&#xA;&#x9;,FORNECEDOR&#xA;&#x9;,CATEGORIA&#xA;&#x9;,PRODUTO&#xA;&#x9;,HP.ID_VERSAO&#xA;&#x9;&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="RESULT_SETS_RESGATES">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE @ID_CAMPANHA INT	= 375DECLARE @DAT_INI VARCHAR(20)		= '2026-04-26'DECLARE @DAT_FIM VARCHAR(20)		= '2026-06-25';

SELECT
	CAST(PC.DATA_RESGATE AS DATE)			AS DATA
	,DP.ID									AS ID_PARTICIPANTE
	,CAST(CONCAT(HP.ID_VERSAO, '-',DP.ID) AS NVARCHAR(MAX))				AS CHAVE_PARTICIPANTE
	,FORNECEDOR
	,CATEGORIA
	,PRODUTO
	,SUM(QUANTIDADE)						AS QUANTIDADE
	,SUM(VALOR_RESGASTADO)					AS VALOR
FROM
	[DB_PREMIOIDEAL].[DBO].[TB_PONTOS_RESGATADOS]				AS PC (NOLOCK)
	INNER JOIN DB_SAFRA.DBO.TB_PARTICIPANTES					AS DP (NOLOCK)
		ON PC.CPF_PARTICIPANTE COLLATE SQL_LATIN1_GENERAL_CP1_CI_AS = DP.CPF
	--LEFT JOIN DB_SAFRA.dbo.TB_ESTABELECIMENTOS_PARTICIPANTES    AS EP (NOLOCK)
	--	ON EP.ID_PARTICIPANTE = DP.ID_PARTICIPANTE
	--LEFT JOIN DB_SAFRA.dbo.TB_ESTABELECIMENTOS					AS E (NOLOCK)
	--	ON E.ID_ESTABELECIMENTO = EP.ID_ESTABELECIMENTO
	INNER JOIN DB_SAFRA.dbo.TB_HIERARQUIA_PARTICIPANTES					AS HP (NOLOCK)
		ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(PC.DATA_RESGATE AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )
WHERE
	ID_CAMPANHA = @ID_CAMPANHA
	AND CAST(PC.DATA_RESGATE AS DATE) BETWEEN @DAT_INI AND @DAT_FIM
GROUP BY
	CAST(PC.DATA_RESGATE AS DATE)
	,DP.ID
	,FORNECEDOR
	,CATEGORIA
	,PRODUTO
	,HP.ID_VERSAO
	</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{92D91CD9-9E28-4396-B56C-7A83CA2026CB}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @DAT_INI VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_INI] +&#xA;&#xA;&quot;DECLARE @DAT_FIM VARCHAR(20)&#x9;&#x9;= &quot; + (DT_WSTR, 20) @[User::DAT_FIM] + &quot;;&#xA;&#xA;SELECT DP.ID&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ID_PARTICIPANTE&#xA;&#x9;  ,CAST(CONCAT(HP.ID_VERSAO, '-', DP.ID) AS NTEXT)&#x9;&#x9;&#x9;AS CHAVE_PARTICIPANTE&#xA;&#x9;  ,E.ID&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS ID_ESTABELECIMENTO&#xA;      ,DATA_VENDA&#xA;&#x9;  ,SUM(VALOR_TOTAL)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS VALOR_TOTAL&#xA;&#x9;  ,SUM(VOP)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS VOP             -- VALOR FINANCIADO&#xA;      ,SUM(QUANTIDADE)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CONTRATOS   -- VOLUME QUANTITATIVO DE CONTRATOS&#xA;&#x9;  ,SUM(CASE &#xA;&#x9;&#x9;WHEN VALOR_TOTAL = 7200 THEN QUANTIDADE &#xA;&#x9;&#x9;ELSE 0 &#xA;&#x9;&#x9;END)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS CONTRATOS_SEGURADOS -- VOLUME QUANTITATIVO DE CONTRATOS COM SEGURO INCLUSO&#xA;  FROM dbo.TB_VENDAS AS V (NOLOCK)&#xA;&#x9;INNER JOIN DBO.TB_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS DP (NOLOCK)&#xA;&#x9;&#x9;ON V.CPF COLLATE SQL_LATIN1_GENERAL_CP1_CI_AS = DP.CPF&#xA;&#x9;LEFT JOIN dbo.TB_ESTABELECIMENTOS&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;AS E (NOLOCK)&#xA;&#x9;&#x9;ON E.CNPJ = V.CNPJ&#xA;&#x9;INNER JOIN dbo.TB_HIERARQUIA_PARTICIPANTES&#x9;&#x9;&#x9;&#x9;&#x9;AS HP (NOLOCK)&#xA;&#x9;&#x9;ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE&#xA;&#x9;&#x9;AND CAST(V.DATA_VENDA AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )&#xA;&#x9;WHERE CAST(DATA_VENDA AS NVARCHAR(10)) BETWEEN @DAT_INI AND @DAT_FIM&#xA; &#x9;GROUP BY  &#xA;&#x9;&#x9;DP.ID&#xA;&#x9;&#x9;,E.ID&#xA;&#x9;&#x9;,HP.ID_VERSAO&#xA;&#x9;&#x9;,DATA_VENDA&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="RESULT_SETS_VENDAS">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE @DAT_INI VARCHAR(20)		= '2026-04-26'DECLARE @DAT_FIM VARCHAR(20)		= '2026-06-25';

SELECT DP.ID													AS ID_PARTICIPANTE
	  ,CAST(CONCAT(HP.ID_VERSAO, '-', DP.ID) AS NTEXT)			AS CHAVE_PARTICIPANTE
	  ,E.ID														AS ID_ESTABELECIMENTO
      ,DATA_VENDA
	  ,SUM(VALOR_TOTAL)											AS VALOR_TOTAL
	  ,SUM(VOP)													AS VOP             -- VALOR FINANCIADO
      ,SUM(QUANTIDADE)											AS CONTRATOS   -- VOLUME QUANTITATIVO DE CONTRATOS
	  ,SUM(CASE 
		WHEN VALOR_TOTAL = 7200 THEN QUANTIDADE 
		ELSE 0 
		END)													AS CONTRATOS_SEGURADOS -- VOLUME QUANTITATIVO DE CONTRATOS COM SEGURO INCLUSO
  FROM dbo.TB_VENDAS AS V (NOLOCK)
	INNER JOIN DBO.TB_PARTICIPANTES										AS DP (NOLOCK)
		ON V.CPF COLLATE SQL_LATIN1_GENERAL_CP1_CI_AS = DP.CPF
	LEFT JOIN dbo.TB_ESTABELECIMENTOS							AS E (NOLOCK)
		ON E.CNPJ = V.CNPJ
	INNER JOIN dbo.TB_HIERARQUIA_PARTICIPANTES					AS HP (NOLOCK)
		ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(V.DATA_VENDA AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )
	WHERE CAST(DATA_VENDA AS NVARCHAR(10)) BETWEEN @DAT_INI AND @DAT_FIM
 	GROUP BY  
		DP.ID
		,E.ID
		,HP.ID_VERSAO
		,DATA_VENDA</DTS:VariableValue>
    </DTS:Variable>
