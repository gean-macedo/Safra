            <component
              refId="Package\CARGA VENDAS\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT DP.ID													AS ID_PARTICIPANTE
	  ,CAST(CONCAT(HP.ID_VERSAO, '-', DP.ID) AS NTEXT)			AS CHAVE_PARTICIPANTE
	  ,E.ID														AS ID_ESTABELECIMENTO
      ,DATA_VENDA
	  ,SUM(VALOR_TOTAL)											AS VALOR_TOTAL
	  ,SUM(VOP)													AS VOP             -- VALOR FINANCIADO
      ,SUM(QUANTIDADE)											AS CONTRATOS   -- VOLUME QUANTITATIVO DE CONTRATOS
	  ,SUM(CASE 
		WHEN VALOR_TOTAL = 7200 THEN QUANTIDADE 
		ELSE 0 
		END)													AS CONTRATOS_SEGURADOS -- VOLUME QUANTITATIVO DE CONTRATOS COM SEGURO INCLUSO
  FROM dbo.TB_VENDAS AS V (NOLOCK)
	INNER JOIN DBO.TB_PARTICIPANTES										AS DP (NOLOCK)
		ON V.CPF COLLATE SQL_LATIN1_GENERAL_CP1_CI_AS = DP.CPF
	LEFT JOIN dbo.TB_ESTABELECIMENTOS							AS E (NOLOCK)
		ON E.CNPJ = V.CNPJ
	INNER JOIN dbo.TB_HIERARQUIA_PARTICIPANTES					AS HP (NOLOCK)
		ON DP.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(V.DATA_VENDA AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )
	WHERE CAST(DATA_VENDA AS NVARCHAR(10)) BETWEEN ? AND ?
	GROUP BY  
		DP.ID
		,E.ID
		,HP.ID_VERSAO
		,DATA_VENDA</property>
                <property
