      DTS:Expression="&quot;'&quot; + (DT_WSTR, 20) (DT_DBDATE) DATEADD(&quot;day&quot;, @[User::RETROAGIR], (DT_DBDATE) REPLACE( @[User::DAT_FIM] , &quot;'&quot;, &quot;&quot;)) + &quot;'&quot;"
