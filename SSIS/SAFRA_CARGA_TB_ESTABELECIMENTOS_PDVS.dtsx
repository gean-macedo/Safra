                  dataType="System.String"
                  description="Specifies the SQL statement used by the component to extract data."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select 
	id::text as id_vendavall
	,'Estabelecimentos' as tabela
	,case when updated_by in ('beb6b98c-f415-4bf7-9436-ad0cb2f451bf', 'dadd7b9c-45a9-4f8a-9bbf-2bddf7a49830') and status = false
		then updated_at 
		end  					   as data_inativacao_api
from
safra_api_vendavall_20240828225002.establishments
WHERE
	CNPJ &lt;&gt; '01239512000178'
and (updated_by in ('beb6b98c-f415-4bf7-9436-ad0cb2f451bf', 'dadd7b9c-45a9-4f8a-9bbf-2bddf7a49830') and status = false)</property>
