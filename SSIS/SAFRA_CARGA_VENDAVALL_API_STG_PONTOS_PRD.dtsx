            <component
              refId="Package\Valida e Retorna Pontos Existentes API\Origem OLE DB 1"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="Origem OLE DB;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; Todos os Direitos Reservados; http://www.microsoft.com/sql/support;7"
              description="Origem OLE DB"
              name="Origem OLE DB 1"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="O tempo em segundos antes que um comando expire. Zero indica uma expiração infinita."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Especifica o nome do objeto de banco de dados usado para abrir um conjunto de linhas."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Especifica a variável que contém o nome do objeto de banco de dados usado para abrir um conjunto de linhas."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="O comando SQL a ser executado."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH CTE_PONTOS AS (
    SELECT DISTINCT
        PA.ID AS ID_PONTO
        ,UPPER(PA.points) AS PONTO
        ,PPS.ID AS ID_PARTICIPANTE
        ,P.ID AS ID_PARTICIPANTE_API
        ,PA.participant_cpf AS CPF
        ,PA.STATUS
        ,'Pontos | Já cadastrado' as ERROR
        ,PA.TRANSACTION_ID
    FROM TB_PONTOS_API AS PA (NOLOCK)
    INNER JOIN DBO.TB_SALES_STG AS S (NOLOCK)
        ON S.type = PA.type
        AND S.nf_number = PA.contract_number
        AND S.item_value = PA.points
        AND S.[sale_date] = CAST(PA.period AS datetime)
        AND S.cpf = PA.participant_cpf
    INNER JOIN TB_PARTICIPANTES_STG AS PPS (NOLOCK)
        ON PA.PARTICIPANT_CPF = PPS.CPF
    LEFT JOIN TB_PARTICIPANTES_API AS P (NOLOCK)
        ON P.CPF = PA.participant_cpf

    UNION ALL

    SELECT DISTINCT
        PA.ID AS ID_PONTO
        ,PA.points AS PONTO
        ,PS.ID AS ID_PARTICIPANTE
        ,P.ID AS ID_PARTICIPANTE_API
        ,PA.participant_cpf AS CPF
        ,PA.STATUS
        ,CASE
            WHEN (PS.DATA_ACEITE_REGULAMENTO IS NULL) 
				OR (PS.STATUS = 1 AND CAST(PA.DATA_REFERENCIA AS DATE) &lt;= CAST(PS.DATA_ACEITE_REGULAMENTO AS DATE))
                OR (PS.STATUS = 6 AND CAST(PA.DATA_REFERENCIA AS DATE) NOT BETWEEN CAST(PS.DATA_ACEITE_REGULAMENTO AS DATE) AND CAST(PS.DATA_UPDATE AS DATE))
                THEN 'Pontos | Data do contrato não permitida'
            WHEN PS.STATUS IN (0, 2, 3, 5) THEN 'Pontos | Status do participante não permite pontuação'
            WHEN PS.CPF IS NULL THEN 'Pontos | Participante não cadastrado'
            WHEN PS.ROLE &lt;&gt; 'VENDEDOR' OR PS.ROLE IS NULL THEN 'Pontos | Cargo não permite pontuação'
            WHEN (PA.CODIGO_SAFRA_REVENDA &lt;&gt; ES.CODIGO_SAFRA_REVENDA
                OR PA.CODIGO_SAFRA_REVENDA IS NULL
                OR ES.CODIGO_SAFRA_REVENDA IS NULL)
                THEN 'Pontos | Código safra inválido'
            WHEN [dbo].[fn_ValidarData](PA.DATA_REFERENCIA) &lt;&gt; 1
				OR [dbo].[fn_ValidarData](PA.VALIDADE) &lt;&gt; 1
				THEN 'Pontos | Data referência inválida'
        END AS ERROR
        ,PA.TRANSACTION_ID
    FROM TB_PONTOS_API AS PA (NOLOCK)
    LEFT JOIN TB_PARTICIPANTES_STG AS PS (NOLOCK)
        ON PA.PARTICIPANT_CPF = PS.CPF
    LEFT JOIN TB_ESTABELECIMENTOS_STG AS ES (NOLOCK)
        ON PA.codigo_safra_revenda = ES.codigo_safra_revenda
    LEFT JOIN TB_PARTICIPANTES_API AS P (NOLOCK)
        ON P.CPF = PA.participant_cpf
    WHERE
        NOT EXISTS (
            SELECT NULL
            FROM DBO.TB_SALES_STG AS S (NOLOCK)
            WHERE
                S.type = PA.type
                AND S.nf_number = PA.contract_number
                AND S.item_value = PA.points
                AND S.[sale_date] = CAST(PA.period AS datetime)
                AND S.cpf = PA.participant_cpf
        )
        AND PA.STATUS = 'PRÉ-APROVADO DLQ'
        AND (CASE
            WHEN (PS.DATA_ACEITE_REGULAMENTO IS NULL) 
				OR (PS.STATUS = 1 AND CAST(PA.DATA_REFERENCIA AS DATE) &lt;= CAST(PS.DATA_ACEITE_REGULAMENTO AS DATE))
                OR (PS.STATUS = 6 AND CAST(PA.DATA_REFERENCIA AS DATE) NOT BETWEEN CAST(PS.DATA_ACEITE_REGULAMENTO AS DATE) AND CAST(PS.DATA_UPDATE AS DATE))
                THEN 'Pontos | Data do contrato não permitida'
            WHEN PS.STATUS IN (0, 2, 3, 5) THEN 'Pontos | Status do participante não permite pontuação'
            WHEN PS.CPF IS NULL THEN 'Pontos | Participante não cadastrado'
            WHEN PS.ROLE &lt;&gt; 'VENDEDOR' OR PS.ROLE IS NULL THEN 'Pontos | Cargo não permite pontuação'
            WHEN (PA.CODIGO_SAFRA_REVENDA &lt;&gt; ES.CODIGO_SAFRA_REVENDA
                OR PA.CODIGO_SAFRA_REVENDA IS NULL
                OR ES.CODIGO_SAFRA_REVENDA IS NULL)
                THEN 'Pontos | Código safra inválido'
            WHEN [dbo].[fn_ValidarData](PA.DATA_REFERENCIA) &lt;&gt; 1
				OR [dbo].[fn_ValidarData](PA.VALIDADE) &lt;&gt; 1
				THEN 'Pontos | Data referência inválida'
        END) IS NOT NULL
)

SELECT NEWID() AS ID, *
FROM CTE_PONTOS;</property>
