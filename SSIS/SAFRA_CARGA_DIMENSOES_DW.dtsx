            <component
              refId="Package\Carrega DIM_PARTICIPANTES\OLE DB Source"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE DB Source"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT		
	TRY_CAST(pa.CPF AS VARCHAR(11))						AS CPF
	,PA.NOME
	,HP.ID_VERSAO
	,PA.ID												AS ID_PARTICIPANTE
	,CAST(CONCAT(HP.ID_VERSAO, '-',PA.ID) AS NTEXT)		AS CHAVE_PARTICIPANTE
	,PA.GENERO
	,UPPER(PA.STATUS)									AS STATUS
	,PH.ID												AS ID_CARGO
	,PA.CEP
	,UPPER(PA.CIDADE)									AS CIDADE
	,UPPER(PA.ESTADO)									AS ESTADO
	,[dbo].[FN_OBTERSIGLAESTADO](PA.ESTADO)				AS UF
	,CAST(DATA_ACEITE_REGULAMENTO AS DATE)				AS DATA_ACEITE_REGULAMENTO
    ,TRY_CAST(DATA_ACEITE_REGULAMENTO AS TIME) AS HORA_ACEITE_REGULAMENTO
    ,CAST(DATA_CRIACAO_PARTICIPANTE AS DATE)			AS DATA_CRIACAO_PARTICIPANTE
    ,TRY_CAST(DATA_CRIACAO_PARTICIPANTE AS TIME) AS HORA_CRIACAO_PARTICIPANTE
    ,CAST(DATA_ATUALIZACAO_PARTICIPANTE AS DATE)		AS DATA_ATUALIZACAO_PARTICIPANTE
    ,TRY_CAST(DATA_ATUALIZACAO_PARTICIPANTE AS TIME) AS HORA_ATUALIZACAO_PARTICIPANTE
	,CAST(DATA_INATIVACAO_PARTICIPANTE_API AS DATE)		AS DATA_INATIVACAO_PARTICIPANTE_API
    ,TRY_CAST(DATA_INATIVACAO_PARTICIPANTE_API AS TIME) AS HORA_INATIVACAO_PARTICIPANTE_API
FROM
	dbo.TB_PARTICIPANTES								AS PA (NOLOCK)
	INNER JOIN dbo.TB_HIERARQUIA_PARTICIPANTES			AS HP (NOLOCK)
		ON PA.ID_PARTICIPANTE = HP.ID_PARTICIPANTE
		AND CAST(GETDATE() AS DATE) BETWEEN DATA_INICIO AND ISNULL(DATA_FIM, CAST(GETDATE() AS DATE) )
	INNER JOIN DBO.TB_PROGRAMA_HIERARQUIA				AS PH (NOLOCK)
		ON PH.ID_HIERARQUIA = HP.ID_HIERARQUIA</property>
