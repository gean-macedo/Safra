                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH Roles AS (
    SELECT 
        'Superintendente'   AS ROLE, CAST('c23532c5-528d-4615-a480-3dbca133cbb4' AS UNIQUEIDENTIFIER) AS CARGO_ID
    UNION ALL SELECT 'Gerente Regional', CAST('f44cfe59-479d-40fe-bfe0-aca68ea7ca01' AS UNIQUEIDENTIFIER)
    UNION ALL SELECT 'Gerente Safra',     CAST('12d68fbe-980d-4367-9702-fce50463a1ce' AS UNIQUEIDENTIFIER)
    UNION ALL SELECT 'Operador',          CAST('04410f4a-9951-4b1b-91a6-9b5ecdba50f8' AS UNIQUEIDENTIFIER)
    UNION ALL SELECT 'Financeiro',        CAST('dd8b038f-c6f2-4597-a24b-b80d6b7eb1ce' AS UNIQUEIDENTIFIER)
    UNION ALL SELECT 'Master',            CAST('4216feeb-f909-46b1-9525-d357bb1d8614' AS UNIQUEIDENTIFIER)
    UNION ALL SELECT 'Gerente Revenda',   CAST('af014b4b-42bc-4c34-a637-0da477090946' AS UNIQUEIDENTIFIER)
    UNION ALL SELECT 'Vendedor',          CAST('12d34563-3ef1-49c3-87ce-ea4b43f35bec' AS UNIQUEIDENTIFIER)
)
SELECT DISTINCT 
    ES.id AS ID_ESTABELECIMENTO,
    PS.id AS ID_PARTICIPANTE,
	PA.establishment_id AS ID_ESTABELECIMENTO_API,
	PA.participant_id AS ID_PARTICIPANTE_API,
    R.CARGO_ID AS ID_CARGO
FROM TB_ESTABELECIMENTOS_PARTICIPANTES_API AS PA WITH (NOLOCK)
INNER JOIN [dbo].[TB_PARTICIPANTES_STG] AS PS WITH (NOLOCK)
    ON PS.cpf = PA.cpf
INNER JOIN [dbo].[TB_ESTABELECIMENTOS_STG] ES WITH (NOLOCK)
    ON PA.cnpj = ES.cnpj
LEFT JOIN Roles R ON R.ROLE = PA.ROLE
INNER JOIN DBO.TB_ESTABELECIMENTOS_PARTICIPANTES_STG AS EPS WITH (NOLOCK)
        ON EPS.establishment_id = ES.id
          AND EPS.participant_id = PS.id
WHERE
    PA.STATUS = 'Inativar' and EPS.STATUS = 1</property>
