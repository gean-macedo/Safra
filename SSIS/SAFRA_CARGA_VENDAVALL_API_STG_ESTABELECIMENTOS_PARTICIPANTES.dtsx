                <property
                  dataType="System.String"
                  description="O comando SQL a ser executado."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT PA.establishment_id as ID_ESTABELECIMENTO
,PA.participant_id as ID_PARTICIPANTE
FROM TB_ESTABELECIMENTOS_PARTICIPANTES_API AS PA (NOLOCK)
INNER JOIN [dbo].[TB_PARTICIPANTES_STG] AS PS (NOLOCK)
ON PS.cpf = PA.cpf
INNER JOIN [dbo].[TB_ESTABELECIMENTOS_STG] ES (NOLOCK)
ON PA.cnpj = ES.cnpj
INNER JOIN DBO.TB_ESTABELECIMENTOS_PARTICIPANTES_STG AS EPS (NOLOCK)
ON EPS.establishment_id = ES.id
			AND EPS.participant_id = PS.id
and PA.STATUS = 'Ativo'</property>
