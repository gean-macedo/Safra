            <component
              refId="Package\Carrega TB_PARTICIPANTES_STG\Origem do ADO NET"
              componentClassID="Microsoft.ManagedComponentHost"
              contactInfo="Consome dados do SQL Server, OLE DB, ODBC ou Oracle usando o provedor de dados .NET Framework correspondente. Use uma instrução Transact-SQL para definir o conjunto de resultados. Por exemplo, extraia dados do SQL Server com o provedor de dados .NET Framework para SQL Server.;Microsoft Corporation; Microsoft SQL Server; © Microsoft Corporation; Todos os Direitos Reservados; http://www.microsoft.com/sql/support;4"
              description="Consome dados do SQL Server, OLE DB, ODBC ou Oracle usando o provedor de dados .NET Framework correspondente. Use uma instrução Transact-SQL para definir o conjunto de resultados. Por exemplo, extraia dados do SQL Server com o provedor de dados .NET Framework para SQL Server."
              name="Origem do ADO NET"
              usesDispositions="true"
              version="4">
              <properties>
                <property
                  dataType="System.String"
                  description="Especifica a instrução SQL usada pelo componente para extrair os dados."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">select 
	p.id::text
	,p.name
	,cpf
	,u.email
	,c."data" as celular
	,ph.name as role
	,status
	,max(case when additional_infos::JSONB -&gt;&gt; 'codigo_operador' = 'N/A' 
			then null
			else additional_infos::JSONB -&gt;&gt; 'codigo_operador' end) AS codigo_operador
	,p.updated_at 
	,max(prt.created_at) as data_aceite_regulamento
 from safra_api_vendavall_20240828225002.participants p 
 left join safra_api_vendavall_20240828225002.users u
 on p.user_id = u.id
 left join safra_api_vendavall_20240828225002.program_participant pp
 on p.id = pp.participant_id
 left join safra_api_vendavall_20240828225002.program_hierarchies ph
 on pp.company_position_id = ph.id
 left join safra_api_vendavall_20240828225002.participant_rule_and_term prt
 on p.id = prt.participant_id
 left join safra_api_vendavall_20240828225002.sales s
 on p.id = s.saler_id 
 left join safra_api_vendavall_20240828225002.contacts c 
 on c.type = 2
        and c.contactable_id = p.id
 group by p.id
	,p.name
	,cpf
	,u.email
	,c."data" 
	,status
	,ph.name
	,p.updated_at</property>
