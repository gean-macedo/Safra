            <component
              refId="Package\Retorno DLQ HIERARQUIA PARTICIPANTES\Origem OLE DB"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="Origem OLE DB;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; Todos os Direitos Reservados; http://www.microsoft.com/sql/support;7"
              description="Origem OLE DB"
              name="Origem OLE DB"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="O tempo em segundos antes que um comando expire. Zero indica uma expiração infinita."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Especifica o nome do objeto de banco de dados usado para abrir um conjunto de linhas."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Especifica a variável que contém o nome do objeto de banco de dados usado para abrir um conjunto de linhas."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="O comando SQL a ser executado."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">WITH BASE AS (
    SELECT 
        HPA.id AS id_t_participant_hierarchy,
        HPA.participant_id AS participant_id_api,
        HPA.superior_participant_id AS superior_participant_id_api,
        P.codigo_operador AS participant_code,
        PS.codigo_operador AS superior_code,
        HPA.status,
        HPA.created_at,
        HPA.updated_at,
        HPA.transaction_id,
        P.id AS participant_id,
        PS.id AS superior_participant_id
    FROM dbo.TB_HIERARQUIA_PARTICIPANTES_API HPA

    LEFT JOIN dbo.TB_PARTICIPANTES_STG P
        ON HPA.cpf = P.cpf

    LEFT JOIN dbo.TB_PARTICIPANTES_STG PS
        ON HPA.cpf_superior = PS.cpf

    WHERE HPA.status IN ('Ativo','Update')
),

VALIDACOES AS (
    SELECT 
        B.*,

        CASE WHEN B.participant_id IS NULL THEN 1 ELSE 0 END AS erro_01,
        CASE WHEN B.superior_participant_id IS NULL THEN 1 ELSE 0 END AS erro_02,
        CASE WHEN B.participant_code = B.superior_code THEN 1 ELSE 0 END AS erro_03,

        -- NOVA REGRA: vínculo já existente e ativo
        CASE 
            WHEN B.status = 'Update'
             AND EXISTS (
                SELECT 1
                FROM TB_HIERARQUIA_PARTICIPANTES_STG D
                WHERE D.participant_id = B.participant_id
                  AND D.superior_participant_id = B.superior_participant_id
                  AND D.status = 1   -- ajuste se o campo for outro (ex: deleted_at IS NULL)
             )
            THEN 1 ELSE 0 
        END AS erro_04

    FROM BASE B
)

SELECT 
    NEWID()                          AS ID,
    V.participant_id_api             AS PARTICIPANT_ID,
    V.participant_code               AS PARTICIPANT_CODE,
    V.id_t_participant_hierarchy     AS ID_T_PARTICIPANT_HIERARCHY,
    V.transaction_id                 AS TRANSACTION_ID,
    E.error_desc                     AS ERROR,
    GETDATE()                        AS CREATED_AT,
    GETDATE()                        AS UPDATED_AT,
    NULL                             AS DELETED_AT,
    E.code_error                     AS CODE_ERROR,
    V.superior_participant_id_api    AS SUPERIOR_PARTICIPANT_ID,
    V.superior_code                  AS SUPERIOR_CODE

FROM VALIDACOES V

CROSS APPLY (
    VALUES
        -- ERROS
        (CASE WHEN V.erro_01 = 1 THEN '01' END, 'Hierarquia | Subordinado não identificado'),
        (CASE WHEN V.erro_02 = 1 THEN '02' END, 'Hierarquia | Superior não identificado'),
        (CASE WHEN V.erro_03 = 1 THEN '03' END, 'Hierarquia | Hierarquia em loop'),
        (CASE WHEN V.erro_04 = 1 THEN '04' END, 'Hierarquia | Vínculo já existente e ativo'),

        -- SUCESSO
        (CASE 
            WHEN V.erro_01 = 0 
             AND V.erro_02 = 0 
             AND V.erro_03 = 0 
             AND V.erro_04 = 0
            THEN '00' 
         END, 'Sucesso')

) E (code_error, error_desc)

WHERE E.code_error IS NOT NULL</property>
                <property
