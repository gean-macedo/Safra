              <properties>
                <property
                  dataType="System.String"
                  description="Especifica a instrução SQL usada pelo componente para extrair os dados."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT  ph.id,
		p.cpf,
		p2.cpf 								as cpf_superior,
		ph.participant_id::text, 
		ph.superior_participant_id::text,
		ph.status, 
		ph.created_at, 
		ph.updated_at, 
		ph.deleted_at
FROM safra_api_vendavall_20240828225002.participant_hierarchy ph
join safra_api_vendavall_20240828225002.participants p
	on ph.participant_id = p.id
join safra_api_vendavall_20240828225002.participants p2
	on ph.superior_participant_id = p2.id</property>
                <property
                  dataType="System.Int32"
                  description="O tempo em segundos antes que um comando expire. Zero indica uma expiração infinita."
                  name="CommandTimeout">30</property>
                <property
                  dataType="System.Boolean"
                  description="Indica a permissão para que as colunas externas que não são de cadeias de caracteres sejam convertidas implicitamente em cadeias de caracteres nas colunas de saída."
                  name="AllowImplicitStringConversion">true</property>
                <property
                  dataType="System.String"
